          <EntitySet Name="UserBalances" EntityType="Self.UserBalances" store:Type="Views" store:Schema="dbo">
            <DefiningQuery>SELECT 
    [UserBalances].[UserID] AS [UserID], 
    [UserBalances].[Balance] AS [Balance], 
    [UserBalances].[LastUpdated] AS [LastUpdated]
    FROM [dbo].[UserBalances] AS [UserBalances]</DefiningQuery>
          </EntitySet>
          <EntitySet Name="UserCreditsLog" EntityType="Self.UserCreditsLog" store:Type="Views" store:Schema="dbo">
            <DefiningQuery>SELECT 
    [UserCreditsLog].[CreditID] AS [CreditID], 
    [UserCreditsLog].[UserID] AS [UserID], 
    [UserCreditsLog].[OrderID] AS [OrderID], 
    [UserCreditsLog].[Amount] AS [Amount], 
    [UserCreditsLog].[Date] AS [Date], 
    [UserCreditsLog].[Type] AS [Type], 
    [UserCreditsLog].[Status] AS [Status]
    FROM [dbo].[UserCreditsLog] AS [UserCreditsLog]</DefiningQuery>
          </EntitySet>
