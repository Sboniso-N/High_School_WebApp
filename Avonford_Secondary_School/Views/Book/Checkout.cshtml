@* ========================= Views/Book/Checkout.cshtml ========================= *@
@model Avonford_Secondary_School.Models.ViewModels.BookCheckoutVM
@{
    ViewBag.Title = "Checkout";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var inv = System.Globalization.CultureInfo.InvariantCulture;
}
<style>
    .stepper {
        display: flex;
        gap: 12px;
        align-items: center;
        margin: 10px 0 20px
    }

    .step {
        display: flex;
        align-items: center;
        gap: 8px
    }

    .dot {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: #ffe8d9;
        color: #b34700;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700
    }

        .dot.active {
            background: #ff6600;
            color: #fff
        }

    .panelish {
        background: #fff;
        border: 1px solid #eee;
        border-radius: 12px;
        padding: 16px;
        box-shadow: 0 8px 20px rgba(0,0,0,.05)
    }

    .btn-accent {
        background: #ff6600;
        color: #fff;
        border: none
    }

        .btn-accent:hover {
            background: #e65c00;
            color: #fff
        }

    .muted {
        color: #888
    }
</style>

<div class="container" style="margin-top:15px">
    <h2 style="margin-top:0">Checkout</h2>
    <div class="stepper">
        <div class="step"><span class="dot active">1</span><span>Options</span></div>
        <span class="muted">—</span>
        <div class="step"><span class="dot active">2</span><span>Summary</span></div>
        <span class="muted">—</span>
        <div class="step"><span class="dot">3</span><span>Done</span></div>
    </div>

    <!-- Feed JS dot-decimal numbers so there's no NaN when locale uses commas -->
    <div id="orderData"
         data-sub="@Model.Subtotal.ToString("0.00", inv)"
         data-fee="@Model.DeliveryFee.ToString("0.00", inv)">
    </div>

    @using (Html.BeginForm("Checkout", "Book", FormMethod.Post, new { id = "checkoutForm" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.BookID)

        <div class="row">
            <div class="col-md-7">
                <div class="panelish">
                    <h4 style="margin-top:0">1) Delivery Option</h4>
                    <div class="radio">
                        <label>
                            @Html.RadioButtonFor(m => m.DeliveryType, "Pickup", new { id = "optPickup" })
                            Collect from seller (no fee)
                        </label>
                    </div>
                    <div class="radio" style="margin-bottom:10px">
                        <label>
                            @Html.RadioButtonFor(m => m.DeliveryType, "Delivery", new { id = "optDelivery" })
                            Delivery (+R @Model.DeliveryFee.ToString("0", inv) )
                        </label>
                    </div>

                    <div id="deliveryWrap" style="display:none">
                        <label for="DeliveryAddress">Delivery Address</label>
                        @Html.TextBoxFor(m => m.DeliveryAddress, new
                        {
                            @class = "form-control",
                            id = "DeliveryAddress",
                            placeholder = "Street, suburb, city, postal code"
                        })
                        @Html.ValidationMessageFor(m => m.DeliveryAddress, "", new { @class = "text-danger" })
                        <small class="muted">We’ll only store the address text to complete this order.</small>
                    </div>
                </div>

                <div class="panelish" style="margin-top:16px">
                    <h4 style="margin-top:0">2) Payment</h4>
                    <div class="radio">
                        <label>
                            @Html.RadioButtonFor(m => m.PaymentMethod, "Wallet", new { id = "payWallet" })
                            Pay with wallet credits
                            @if (!Model.BuyerHasEnoughWallet)
                            {
                                <span class="label label-danger">Insufficient</span>
                            }
                        </label>
                    </div>
                    <div class="radio">
                        <label>
                            @Html.RadioButtonFor(m => m.PaymentMethod, "Card", new { id = "payCard" })
                            Card (Stripe)
                        </label>
                    </div>
                    <div class="radio">
                        <label>
                            @Html.RadioButtonFor(m => m.PaymentMethod, "EFT", new { id = "payEft" })
                            EFT (upload proof later)
                        </label>
                    </div>
                    @Html.ValidationMessageFor(m => m.PaymentMethod, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="col-md-5">
                <div class="panelish">
                    <h4 style="margin-top:0">Order Summary</h4>
                    <div style="display:flex; justify-content:space-between; margin:6px 0">
                        <span>Book</span><strong>R <span id="sub">@Model.Subtotal.ToString("0.00", inv)</span></strong>
                    </div>
                    <div style="display:flex; justify-content:space-between; margin:6px 0">
                        <span>Delivery</span><strong>R <span id="del">0.00</span></strong>
                    </div>
                    <hr style="margin:10px 0" />
                    <div style="display:flex; justify-content:space-between; font-size:18px">
                        <span>Total</span><strong>R <span id="tot">@Model.Subtotal.ToString("0.00", inv)</span></strong>
                    </div>
                    <div class="text-right" style="margin-top:14px">
                        <button id="payBtn" type="submit" class="btn btn-accent btn-lg">
                            <span class="glyphicon glyphicon-lock"></span> Confirm & Pay
                        </button>
                    </div>
                    <small class="muted">Seller receives 80% of the book price. Delivery fee goes to the platform.</small>
                </div>
            </div>
        </div>
    }
</div>

@section scripts{
    <!-- Google Places (for address autocomplete) -->
    <script src="https://maps.googleapis.com/maps/api/js?key=@Model.GoogleMapsApiKey&libraries=places"></script>
    <script>
    (function(){
        // Numbers: always parse dot-decimal from data-* to avoid NaN on comma locales
        var data = document.getElementById('orderData');
        var sub = parseFloat(data.getAttribute('data-sub')) || 0;
        var fee = parseFloat(data.getAttribute('data-fee')) || 0;

        var elDel = document.getElementById('del');
        var elTot = document.getElementById('tot');
        var elBtn = document.getElementById('payBtn');
        var optPickup = document.getElementById('optPickup');
        var optDelivery = document.getElementById('optDelivery');
        var dWrap = document.getElementById('deliveryWrap');
        var addr = document.getElementById('DeliveryAddress');

        function recalc() {
            var isDel = !!(optDelivery && optDelivery.checked);
            elDel.textContent = (isDel ? fee : 0).toFixed(2);
            elTot.textContent = (sub + (isDel ? fee : 0)).toFixed(2);
            dWrap.style.display = isDel ? 'block' : 'none';
        }

        if (optPickup) optPickup.addEventListener('change', recalc);
        if (optDelivery) optDelivery.addEventListener('change', recalc);
        recalc(); // initial

        
        document.getElementById('checkoutForm').addEventListener('submit', function(){
            elBtn.disabled = true;
            elBtn.innerHTML = '<span class="glyphicon glyphicon-refresh spinning"></span> Processing…';
            var style = document.createElement('style');
            style.innerHTML = '.spinning{animation:spin 1s linear infinite}@@keyframes spin{to{transform:rotate(360deg)}}';
            document.head.appendChild(style);
        });

        // --- Google Places Autocomplete on the plain text address ---
        try {
            if (addr) {
                var ac = new google.maps.places.Autocomplete(addr, { types: ['geocode'] });
                ac.addListener('place_changed', function(){
                    var place = ac.getPlace();
                    if (place && place.formatted_address) {
                        addr.value = place.formatted_address; // we only store the text
                    }
                });
            }
        } catch(e) {
            console.warn('Places API unavailable:', e);
        }
    })();
    </script>
}
