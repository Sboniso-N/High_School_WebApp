@model Avonford_Secondary_School.Models.ViewModels.ReturnVMs.BuyerReturnListVM
@{
    ViewBag.Title = "My Returns";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .panelish {
        background: #fff;
        border: 1px solid #eee;
        border-radius: 12px;
        padding: 16px;
        box-shadow: 0 8px 20px rgba(0,0,0,.05)
    }

    .kpi {
        display: flex;
        gap: 12px;
        margin-bottom: 12px;
        flex-wrap: wrap
    }

        .kpi .card {
            flex: 1 1 160px;
            background: #f8fafc;
            border: 1px solid #eef2f7;
            border-radius: 12px;
            padding: 12px;
            text-align: center
        }

    .badge {
        border-radius: 999px;
        padding: 4px 10px;
        font-size: 12px
    }

    .b-pending {
        background: #fff3cd;
        color: #8a6d3b
    }

    .b-needs {
        background: #e3f2fd;
        color: #0d47a1
    }

    .b-refunded {
        background: #e8f5e9;
        color: #2e7d32
    }

    .b-declined {
        background: #ffebee;
        color: #b71c1c
    }

    .btn-xs {
        padding: 4px 8px;
        font-size: 12px;
        border-radius: 8px
    }
</style>

<div class="container" style="margin-top:15px">
    <div class="panelish">
        <h3 style="margin-top:0">My Return Requests</h3>

        <div class="kpi">
            <div class="card"><div>Pending</div><div style="font-size:20px;font-weight:700">@Model.TotalPending</div></div>
            <div class="card"><div>Needs Info</div><div style="font-size:20px;font-weight:700">@Model.TotalNeedsInfo</div></div>
            <div class="card"><div>Refunded</div><div style="font-size:20px;font-weight:700">@Model.TotalRefunded</div></div>
            <div class="card"><div>Declined</div><div style="font-size:20px;font-weight:700">@Model.TotalDeclined</div></div>
        </div>

        <div class="text-right" style="margin-bottom:6px">
            <button id="btnRefresh" class="btn btn-default btn-xs">Refresh</button>
        </div>

        <div class="table-responsive">
            <table class="table table-hover" id="returnsTable">
                <thead>
                    <tr>
                        <th>RMA #</th>
                        <th>Order #</th>
                        <th>Book</th>
                        <th>Reason</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Decision</th>
                        <th class="text-right">Refund</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Items)
                    {
                        var badgeClass =
                            r.Status == "Pending" ? "b-pending" :
                            r.Status == "NeedsInfo" ? "b-needs" :
                            r.Status == "Refunded" ? "b-refunded" :
                            r.Status == "Declined" ? "b-declined" : "b-pending";

                        <tr data-return-id="@r.ReturnID">
                            <td>@r.ReturnID</td>
                            <td>@r.OrderID</td>
                            <td>@r.BookTitle</td>
                            <td>@r.Reason</td>
                            <td><span class="badge @badgeClass js-status">@r.Status</span></td>
                            <td>@r.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="js-decision">@r.DecisionAt</td>
                            <td class="text-right js-refund">R @r.RefundTotal.ToString("0.00")</td>
                            <td class="text-right">
                                <a href="@Url.Action("ReturnDetails","Book", new { id = r.ReturnID })"
                                   class="btn btn-info btn-xs">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="text-right">
            <a class="btn btn-default" href="@Url.Action("MyOrders","Book")">Back to Orders</a>
        </div>
    </div>
</div>

<script>
(function () {
    function cssForStatus(s) {
        s = (s || "").toLowerCase();
        if (s === "refunded") return "b-refunded";
        if (s === "declined") return "b-declined";
        if (s === "needsinfo") return "b-needs";
        return "b-pending";
    }

    function refreshRow(tr) {
        var id = tr.getAttribute("data-return-id");
        if (!id) return;
        fetch('@Url.Action("ReturnStatus","Book")?id=' + encodeURIComponent(id))
            .then(r => r.json())
            .then(j => {
                if (!j || !j.ok) return;
                var statusEl = tr.querySelector(".js-status");
                statusEl.textContent = j.status;
                statusEl.className = "badge js-status " + cssForStatus(j.status);

                var decEl = tr.querySelector(".js-decision");
                decEl.textContent = j.decisionAt || "";

                var refEl = tr.querySelector(".js-refund");
                var total = (j.refundTotal || 0).toFixed(2);
                refEl.textContent = "R " + total;
            })
            .catch(() => { /* silent */ });
    }

    function refreshAll() {
        document.querySelectorAll("#returnsTable tbody tr").forEach(refreshRow);
    }

    document.getElementById("btnRefresh").addEventListener("click", refreshAll);
    // auto-refresh every 20s
    setInterval(refreshAll, 20000);
})();
</script>
