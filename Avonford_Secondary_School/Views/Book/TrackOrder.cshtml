@model Avonford_Secondary_School.Models.ViewModels.TrackOrderVM
@using System.Web
@{
    ViewBag.Title = "Track Order";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var hasDriver = Model.DriverID.HasValue;
}
<style>
    .panelish {
        background: #fff;
        border: 1px solid #eee;
        border-radius: 12px;
        padding: 16px;
        box-shadow: 0 8px 20px rgba(0,0,0,.05)
    }

    .stepper {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap
    }

    .step {
        display: flex;
        align-items: center;
        gap: 6px
    }

        .step .dot {
            width: 12px;
            height: 12px;
            border-radius: 50%
        }

    .done .dot {
        background: #22c55e
    }

    .current .dot {
        background: #3b82f6
    }

    .pending .dot {
        background: #cbd5e1
    }

    .muted {
        color: #6b7280
    }
</style>

<div class="container" style="margin-top:15px">
    <div class="panelish">
        <h3 style="margin-top:0">Track Order #@Model.OrderID</h3>
        <div class="muted">@Model.BookTitle</div>

        <!-- Status stepper -->
        @{
            var step = (Model.CurrentStep ?? "Confirmed").ToLower();
            Func<string, string> cls = s => s == step ? "step current" :
                 (new[] { "confirmed", "pickup", "ontheway", "delivered" }.ToList().IndexOf(s)
                 <= new[] { "confirmed", "pickup", "ontheway", "delivered" }.ToList().IndexOf(step) ? "step done" : "step pending");
        }
        <div class="stepper" style="margin:10px 0 20px">
            <div class="@cls("confirmed")"><span class="dot"></span><span>Order Confirmed</span></div>
            <div class="@cls("pickup")"><span class="dot"></span><span>Preparing for Pickup</span></div>
            <div class="@cls("ontheway")"><span class="dot"></span><span>Delivery Underway</span></div>
            <div class="@cls("delivered")"><span class="dot"></span><span>Delivered</span></div>
        </div>

        <div class="row">
            <div class="col-sm-7">
                <div id="staticMapPanel" class="panelish" style="padding:0;overflow:hidden">
                    <div id="map" style="height:420px;width:100%"></div>
                </div>
            </div>
            <div class="col-sm-5">
                <div class="panelish">
                    <h4 style="margin-top:0">Order Details</h4>
                    <div><strong>Status:</strong> @Model.Status</div>
                    <div><strong>Delivery:</strong> @Model.DeliveryType</div>
                    @if (!string.IsNullOrWhiteSpace(Model.DeliveryAddress))
                    {
                        <div><strong>Deliver to:</strong> @Model.DeliveryAddress</div>
                    }
                    <hr />
                    @if (hasDriver)
                    {
                        <div><strong>Driver:</strong> @Model.DriverName (@Model.DriverStatus)</div>
                        <div class="muted" id="lastPing">Last updated: @(Model.LastPingAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")</div>
                        <button id="btnRefresh" class="btn btn-sm btn-default" style="margin-top:8px">Refresh Driver</button>
                    }
                    else
                    {
                        <div class="muted">A driver has not been assigned yet.</div>
                    }
                </div>
            </div>
        </div>
        <div class="text-right">
            <a class="btn btn-default" href="@Url.Action("MyOrders","Book")">Back to My Orders</a>
        </div>
    </div>
</div>

@if (hasDriver)
{
    <script src="https://maps.googleapis.com/maps/api/js?key=@ViewBag.GoogleMapsApiKey"></script>
    <script>
        (function(){
            var map, directionsService, directionsRenderer;
            var destAddress = "@Html.Raw(HttpUtility.JavaScriptStringEncode(Model.DeliveryAddress ?? "" , true))";
            var pollUrl = "@Url.Action("GetDriverLastLocation","Book", new { orderId = Model.OrderID })";
            var driverMarker = null, destLatLng = null;

            function init(){
                map = new google.maps.Map(document.getElementById('map'), {
                    center: {lat: -29.8587, lng: 31.0218}, // Durban default
                    zoom: 12
                });
                directionsService = new google.maps.DirectionsService();
                directionsRenderer = new google.maps.DirectionsRenderer({suppressMarkers:true});
                directionsRenderer.setMap(map);

                geocodeDest(destAddress, function(latlng){
                    destLatLng = latlng;
                    new google.maps.Marker({position: latlng, map: map, title: "Destination"});
                    poll();
                    setInterval(poll, 15000);
                });
                document.getElementById('btnRefresh').addEventListener('click', poll);
            }

            function geocodeDest(address, cb){
                var geocoder = new google.maps.Geocoder();
                geocoder.geocode({address: address}, function(res, status){
                    if(status === 'OK' && res[0]){
                        cb(res[0].geometry.location);
                    }
                });
            }

            function poll(){
                fetch(pollUrl).then(r=>r.json()).then(j=>{
                    if(!j.ok || !j.hasLocation) return;
                    var here = new google.maps.LatLng(j.lat, j.lng);

                    if(!driverMarker){
                        driverMarker = new google.maps.Marker({
                            position: here, map: map, label: "D", title: "Driver"
                        });
                    }else{
                        driverMarker.setPosition(here);
                    }

                    document.getElementById('lastPing').innerText = "Last updated: " + (j.ts || "");

                    if(destLatLng){
                        directionsService.route({
                            origin: here,
                            destination: destLatLng,
                            travelMode: google.maps.TravelMode.DRIVING
                        }, function(result, status){
                            if(status === 'OK'){
                                directionsRenderer.setDirections(result);
                                var bounds = new google.maps.LatLngBounds();
                                bounds.extend(here);
                                bounds.extend(destLatLng);
                                map.fitBounds(bounds);
                            }
                        });
                    }
                });
            }

            window.addEventListener('load', init);
        })();
    </script>
}
