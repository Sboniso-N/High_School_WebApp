@* ========================= Views/Book/BorrowReturn.cshtml ========================= *@
@model Avonford_Secondary_School.Models.ViewModels.BorrowVMs.BorrowReturnStartVM
@{
    ViewBag.Title = "Return — " + Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .wrap { margin-top:16px }
    .card { background:#fff;border:1px solid #eee;border-radius:14px;box-shadow:0 10px 24px rgba(0,0,0,.06);padding:18px }
    .kv { margin:6px 0 }
    .chip { border-radius:999px;padding:4px 10px;background:#f1f5f9;color:#0f172a;font-size:12px }
    .muted { color:#64748b }
    .danger { color:#b91c1c }
    .uploader { border:2px dashed #e2e8f0;border-radius:12px;padding:16px;text-align:center;cursor:pointer;background:#fafafa }
    .uploader.drag { background:#eef2ff;border-color:#c7d2fe }
    .thumbs { display:flex; gap:8px; flex-wrap:wrap; margin-top:10px }
    .thumb { width:80px;height:80px;object-fit:cover;border-radius:8px;border:1px solid #e5e7eb }
    .btn-accent { background:#ff6600;color:#fff;border:none }
    .btn-accent:hover { background:#e65c00;color:#fff }
    .grid { display:grid; grid-template-columns: 1fr 340px; gap:16px }
    @@media (max-width:992px){ .grid { grid-template-columns: 1fr } }
</style>

<div class="container wrap">
    <h3 style="margin-top:4px">Return book: <span class="muted">@Model.Title</span></h3>

    <div class="grid">
        <div class="card">
            @using (Html.BeginForm("BorrowReturn", "Book", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.ReservationID)
                @Html.HiddenFor(m => m.BookID)

                <div class="kv"><b>Start:</b> @Model.StartAt.ToString("yyyy-MM-dd")</div>
                <div class="kv"><b>Due:</b> @Model.DueAt?.ToString("yyyy-MM-dd")</div>

                <hr />
                <div class="kv">
                    <label for="Comment"><b>Comments (optional)</b></label>
                    <textarea id="Comment" name="Comment" class="form-control" rows="4" maxlength="600"
                              placeholder="Tell the admin about the condition or anything they should know…">@Model.Comment</textarea>
                    <small class="muted"><span id="cc">0</span>/600</small>
                </div>

                <div class="kv">
                    <b>Photos (optional, up to 4)</b>
                    <div id="drop" class="uploader">
                        <div><span class="glyphicon glyphicon-upload"></span> Drag & drop images here or click to choose</div>
                        <small class="muted">JPG/PNG, max ~5MB each</small>
                        <input id="fileInput" name="Photos" type="file" accept="image/*" multiple style="display:none" />
                    </div>
                    <div id="thumbs" class="thumbs"></div>
                </div>

                <hr />
                <div class="muted" style="margin-bottom:10px">
                    Submitting a return sets your reservation status to <span class="chip">ReturnedPendingApproval</span>.
                    An admin will review photos/condition and finalize the invoice. Late returns incur 5%/day after the due date.
                </div>

                <div class="text-right">
                    <a class="btn btn-default" href="@Url.Action("BorrowDetails", "Book", new { id = Model.ReservationID })">Cancel</a>
                    <button type="submit" class="btn btn-accent">Submit Return</button>
                </div>
            }
        </div>

        <div class="card">
            <h4 style="margin-top:0">Estimated fees</h4>
            <div class="kv"><span class="chip">Usage days:</span> @Model.EstUsageDays</div>
            <div class="kv"><span class="chip">Late days:</span> @Model.EstLateDays</div>
            <div class="kv"><b>Fee/day:</b> R @Model.FeePerDay.ToString("0.00")</div>
            <div class="kv"><b>Late fee/day:</b> R @Model.LateFeePerDay.ToString("0.00")</div>
            <hr />
            <div class="kv"><b>Estimated borrow fee:</b> R @Model.EstBorrowFee.ToString("0.00")</div>
            <div class="kv"><b>Estimated late fee:</b> R @Model.EstLateFee.ToString("0.00")</div>
            <div class="kv" style="font-size:18px"><b>Total (estimate):</b> R @Model.EstTotal.ToString("0.00")</div>
            <small class="muted">Final total is calculated after admin approval.</small>
        </div>
    </div>
</div>

@section scripts{
    <script>
(function(){
    // comment counter
    var ta = document.getElementById('Comment'), cc = document.getElementById('cc');
    if(ta){ let up=()=>cc.textContent = ta.value.length; ta.addEventListener('input', up); up(); }

    // uploader
    var drop = document.getElementById('drop');
    var fi = document.getElementById('fileInput');
    var thumbs = document.getElementById('thumbs');

    function addThumb(file){
        var url = URL.createObjectURL(file);
        var img = document.createElement('img');
        img.className = 'thumb';
        img.src = url;
        thumbs.appendChild(img);
    }

    drop.addEventListener('click', ()=> fi.click());
    fi.addEventListener('change', e=>{
        thumbs.innerHTML = '';
        [...fi.files].slice(0,4).forEach(addThumb);
    });

    ;['dragenter','dragover'].forEach(evt => drop.addEventListener(evt, e=>{
        e.preventDefault(); e.stopPropagation(); drop.classList.add('drag');
    }));
    ;['dragleave','drop'].forEach(evt => drop.addEventListener(evt, e=>{
        e.preventDefault(); e.stopPropagation(); drop.classList.remove('drag');
    }));
    drop.addEventListener('drop', e=>{
        var files = [...e.dataTransfer.files].filter(f=>/^image\//.test(f.type)).slice(0,4);
        // put into the hidden input (DataTransfer shim)
        var dt = new DataTransfer();
        files.forEach(f=>dt.items.add(f));
        fi.files = dt.files;
        thumbs.innerHTML = '';
        files.forEach(addThumb);
    });
})();
    </script>
}
