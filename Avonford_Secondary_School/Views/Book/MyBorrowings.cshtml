@* List all your borrow reservations *@
@model Avonford_Secondary_School.Models.ViewModels.BorrowVMs.MyBorrowingsVM
@{
    ViewBag.Title = "My Borrowings";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .panelish {
        background: #fff;
        border: 1px solid #eee;
        border-radius: 12px;
        padding: 16px;
        box-shadow: 0 8px 20px rgba(0,0,0,.05)
    }

    .badge {
        border-radius: 999px;
        padding: 4px 10px;
        font-size: 12px
    }

    .status-Reserved {
        background: #e0f2fe;
        color: #075985
    }

    .status-Active {
        background: #ecfccb;
        color: #3f6212
    }

    .status-ReturnedPendingApproval {
        background: #fef9c3;
        color: #854d0e
    }

    .status-AwaitingPayment {
        background: #ede9fe;
        color: #5b21b6
    }

    .status-Closed {
        background: #f1f5f9;
        color: #334155
    }
</style>

<div class="container" style="margin-top:15px">
    <div class="panelish">
        <h3 style="margin-top:0">My Borrowings</h3>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Book</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Status</th>
                        <th class="text-right">Planned</th>
                        <th style="width:120px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items == null || !Model.Items.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted">No reservations yet.</td></tr>
                    }
                    else
                    {
                        foreach (var x in Model.Items)
                        {
                            <tr>
                                <td>@x.ReservationID</td>
                                <td>@x.Title</td>
                                <td>@x.StartDate</td>
                                <td>@x.EndDate</td>
                                <td><span class="badge status-@x.Status.Replace(" ","")">@x.Status</span></td>
                                <td class="text-right">R @(x.PlannedBorrowFee ?? 0m)</td>
                                <td>
                                    <a class="btn btn-xs btn-info" href="@Url.Action("BorrowDetails","Book", new { id = x.ReservationID })">View</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <div class="text-right">
            <a class="btn btn-default" href="@Url.Action("Index","Book")">Browse Books</a>
        </div>
    </div>
</div>
