@model IEnumerable<Avonford_Secondary_School.Models.ViewModels.MyOrderItemVM>
@{
    ViewBag.Title = "My Orders";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Build a set of orderIds that already have an RMA
    var filed = ViewBag.ReturnedOrderIds as ISet<int>;
    if (filed == null)
    {
        var list = ViewBag.ReturnedOrderIds as IEnumerable<int>;
        filed = new HashSet<int>(list ?? Enumerable.Empty<int>());
    }
}

@functions{
    // Only allow return when delivered/completed and no RMA exists yet
    bool CanFileReturn(Avonford_Secondary_School.Models.ViewModels.MyOrderItemVM o, ISet<int> filedSet)
    {
        var st = (o.Status ?? "").Trim();
        bool deliveredOrCompleted =
            st.Equals("Delivered", StringComparison.OrdinalIgnoreCase) ||
            st.Equals("Completed", StringComparison.OrdinalIgnoreCase); // use if you have this status
        return deliveredOrCompleted && !filedSet.Contains(o.OrderID);
    }
}

<style>
    .panelish {
        background: #fff;
        border: 1px solid #eee;
        border-radius: 12px;
        padding: 16px;
        box-shadow: 0 8px 20px rgba(0,0,0,.05)
    }

    .badge-status {
        border-radius: 999px;
        padding: 4px 10px;
        font-size: 12px
    }

    .status-AwaitingDriver {
        background: #fff3cd;
        color: #9a6b00
    }

    .status-Paid, .status-Delivered {
        background: #e8f5e9;
        color: #2e7d32
    }

    .status-Refunded {
        background: #ffebee;
        color: #b71c1c
    }

    .status-Cancelled {
        background: #eceff1;
        color: #455a64
    }

    .btn-xs {
        padding: 4px 8px;
        font-size: 12px;
        border-radius: 8px
    }

    .btn-warning {
        background: #f59e0b;
        color: #111;
        border: 0
    }

    .btn-info {
        background: #0ea5e9;
        color: #fff;
        border: 0
    }
</style>

<div class="container" style="margin-top:15px">
    <div class="panelish">
        <h3 class="accent" style="margin-top:0">My Orders</h3>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Book</th>
                        <th>Status</th>
                        <th>Delivery</th>
                        <th>Date</th>
                        <th class="text-right">Total</th>
                        <th style="width:220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        var st = o.Status ?? "";
                        var when = o.PaidAt ?? o.CreatedAt;
                        <tr>
                            <td>@o.OrderID</td>
                            <td>@o.BookTitle</td>
                            <td><span class="badge-status @( "status-" + st )">@st</span></td>
                            <td>@o.DeliveryType</td>
                            <td>@when.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="text-right">R @o.Total.ToString("0.00")</td>
                            <td>
                                @* Track button (existing) *@
                                @if (o.CanTrack)
                                {
                                    <a class="btn btn-xs btn-info" href="@Url.Action("TrackOrder","Book", new { id = o.OrderID })">
                                        Track
                                    </a>
                                }

                                @* NEW: Return button (only shows when eligible) *@
                                @if (CanFileReturn(o, filed))
                                {
                                    <a class="btn btn-xs btn-warning"
                                       href="@Url.Action("ReturnCreate","Book", new { orderId = o.OrderID })"
                                       title="File a return for this order">
                                        Return
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="text-right">
            <a class="btn btn-default" href="@Url.Action("Index","Book")">Keep Browsing</a>
        </div>
    </div>
</div>
