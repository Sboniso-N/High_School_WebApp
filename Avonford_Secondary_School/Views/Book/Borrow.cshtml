@* Borrow: choose start date + duration; live fee & availability *@
@model Avonford_Secondary_School.Models.ViewModels.BorrowVMs.BorrowStartVM
@{
    ViewBag.Title = "Borrow “" + Model.Title + "”";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .panelish {
        background: #fff;
        border: 1px solid #eee;
        border-radius: 12px;
        padding: 16px;
        box-shadow: 0 8px 20px rgba(0,0,0,.05)
    }

    .chip {
        background: #f5f7ff;
        border: 1px solid #dfe3ff;
        border-radius: 999px;
        padding: 3px 10px;
        font-size: 12px;
        margin-right: 6px;
        color: #334
    }

    .fee {
        font-size: 20px;
        font-weight: 700
    }

    .muted {
        color: #6b7280
    }

    .btn-accent {
        background: #ff6600;
        color: #fff;
        border: none
    }

        .btn-accent:hover {
            background: #e65c00;
            color: #fff
        }
</style>

<div class="container" style="margin-top:15px">
    <div class="panelish">
        <h3 style="margin-top:0">Borrow “@Model.Title”</h3>
        <div class="muted">Condition: @Model.Condition • Price: R @Model.BookPrice.ToString("0.00")</div>
        <div style="margin:10px 0">
            <span class="chip">Fee/day: <strong>R @Model.FeePerDay.ToString("0.00")</strong></span>
            @if (Model.NextAvailableDate.HasValue)
            {
                <span class="chip">Next available: @Model.NextAvailableDate.Value.ToString("yyyy-MM-dd")</span>
            }
            <span class="chip">@Model.PolicyNote</span>
        </div>

        @using (Html.BeginForm("BorrowPreview", "Book", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            @Html.HiddenFor(m => m.BookID)

            <div class="row">
                <div class="col-sm-4">
                    <div class="form-group">
                        <label>Start date</label>
                        @Html.TextBoxFor(m => m.StartDate, new { @class = "form-control", type = "date", min = Model.MinStartDate.ToString("yyyy-MM-dd"), id = "start" })
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="form-group">
                        <label>Days</label>
                        @Html.TextBoxFor(m => m.RequestedDays, new { @class = "form-control", type = "number", min = "1", max = "60", id = "days" })
                    </div>
                </div>
                <div class="col-sm-4">
                    <label>Ends</label>
                    <div class="form-control" id="endPreview" style="background:#f9fafb">—</div>
                </div>
            </div>

            <div class="row" style="margin-top:8px">
                <div class="col-sm-8">
                    <div id="availability" class="muted">Checking availability…</div>
                </div>
                <div class="col-sm-4 text-right">
                    <div class="fee">Planned total: R <span id="planned">@Model.PlannedBorrowFee.ToString("0.00")</span></div>
                </div>
            </div>

            <div class="text-right" style="margin-top:14px">
                <a class="btn btn-default" href="@Url.Action("Details","Book", new { id = Model.BookID })">Back</a>
                <button class="btn btn-accent">Review & Confirm</button>
            </div>
        }

        @if (Model.Blocked != null && Model.Blocked.Any())
        {
            <hr />
            <h4 class="muted" style="margin-top:0">Upcoming reserved windows</h4>
            <ul class="list-unstyled" style="margin:0">
                @foreach (var i in Model.Blocked)
                {
                    <li>• @i.Start.ToString("yyyy-MM-dd") → @i.End.ToString("yyyy-MM-dd")</li>
                }
            </ul>
        }
    </div>
</div>

@section scripts{
    <script>
(function(){
    const startEl = document.getElementById('start');
    const daysEl  = document.getElementById('days');
    const endEl   = document.getElementById('endPreview');
    const plannedEl = document.getElementById('planned');
    const availEl = document.getElementById('availability');

    function ymd(d){ return d.toISOString().slice(0,10); }

    function calcEnd(){
        const s = new Date(startEl.value);
        let days = parseInt(daysEl.value||'1',10);
        if(isNaN(days) || days<1) days = 1;
        const end = new Date(s); end.setDate(end.getDate() + (days-1));
        endEl.textContent = isNaN(end.getTime()) ? '—' : ymd(end);
    }

    async function refresh(){
        calcEnd();
        const start = startEl.value;
        const days = daysEl.value || 1;
        if(!start) { availEl.textContent = 'Pick a start date.'; return; }

        availEl.textContent = 'Checking availability…';
        try{
            const url = '@Url.Action("CheckBorrowAvailability","Book")' + '?bookId=@Model.BookID&start=' + start + '&days=' + days;
            const r = await fetch(url);
            const j = await r.json();
            if(!j.ok){ availEl.textContent = 'Could not check right now.'; return; }

            plannedEl.textContent = (j.planned || 0).toFixed(2);
            if(j.conflict){
                availEl.innerHTML = '⚠️ Those dates conflict. Next available: <strong>' + (j.nextAvailable || '—') + '</strong>';
            } else {
                availEl.textContent = '✅ Available';
            }
        }catch(e){
            availEl.textContent = 'Could not check right now.';
        }
    }

    startEl.addEventListener('change', refresh);
    daysEl.addEventListener('input', refresh);

    // init with current values
    refresh();
})();
    </script>
}
