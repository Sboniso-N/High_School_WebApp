@{
    var isStudent = Session["Role"] != null && Session["Role"].ToString() == "Student";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - Avonford Secondary School</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- FontAwesome for icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <!-- Animate.css for easy fade/slide in -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" rel="stylesheet" />

    <script src="~/Scripts/modernizr-2.8.3.js"></script>
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>

    <!-- Custom 800+ lines theme CSS -->
    <style>
            /* ======== Reset & Core Theme ======== */
            html, body {
                height: 100%;
                min-height: 100vh;
            }

            body {
                background: #f8fafc;
                color: #23272b;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                margin: 0;
                padding: 0;
                font-size: 16px;
                line-height: 1.7;
                box-sizing: border-box;
            }

            a {
                color: #ff6600;
                text-decoration: none;
                transition: color 0.2s;
            }

                a:hover, a:focus {
                    color: #e65c00;
                    text-decoration: underline;
                }

            img {
                max-width: 100%;
                height: auto;
            }

            /* ======= Navbar Styling ======= */
            .navbar-student {
                background: #ff6600;
                box-shadow: 0 2px 10px rgba(0,0,0,.08);
            }

                .navbar-student .navbar-brand {
                    font-size: 1.9rem;
                    font-weight: bold;
                    color: #fff !important;
                    letter-spacing: 1.5px;
                }

                .navbar-student .nav-link, .navbar-student .dropdown-item {
                    color: #fff !important;
                    font-weight: 500;
                    transition: background 0.2s, color 0.2s;
                    font-size: 1.1rem;
                    border-radius: 6px;
                }

                    .navbar-student .nav-link:hover, .navbar-student .dropdown-item:hover,
                    .navbar-student .nav-link.active {
                        color: #ff6600 !important;
                        background: #fff !important;
                    }

            .navbar-toggler {
                border: none;
            }

                .navbar-toggler:focus {
                    outline: none;
                    box-shadow: none;
                }

            /* ======= Footer ======= */
            footer {
                background: #222;
                color: #ccc;
                padding: 36px 0 18px 0;
                text-align: center;
                font-size: 1.1rem;
                margin-top: 60px;
            }

                footer h4 {
                    color: #ff6600;
                    font-size: 1.2rem;
                    font-weight: bold;
                    margin-bottom: 18px;
                }

                footer a {
                    color: #ff6600;
                    transition: color 0.2s;
                }

                    footer a:hover {
                        color: #fff;
                        text-decoration: underline;
                    }

                footer .footer-links, footer .footer-social {
                    list-style: none;
                    padding: 0;
                    margin: 0;
                }

                    footer .footer-links li, footer .footer-social li {
                        margin-bottom: 8px;
                    }

            .footer-social i {
                font-size: 22px;
                margin-right: 10px;
            }

            /* ======= Cards, Panels & Containers ======= */
            .card, .panel, .custom-card {
                border-radius: 14px;
                box-shadow: 0 4px 16px rgba(0,0,0,0.10);
                border: 0;
                background: #fff;
                margin-bottom: 30px;
            }

            .card-header, .panel-heading {
                background: #ff6600;
                color: #fff;
                font-weight: bold;
                border-radius: 14px 14px 0 0;
                border-bottom: 1.5px solid #fff7f2;
            }

            .card-body, .panel-body {
                padding: 28px 22px 22px 22px;
            }

            .shadow-hover:hover {
                box-shadow: 0 8px 32px rgba(0,0,0,0.18) !important;
            }

            /* ======= Subject & Grid Cards ======= */
            .subject-card {
                background: #fff5ed;
                border: 2px solid #ff6600;
                border-radius: 10px;
                padding: 25px 20px;
                text-align: center;
                transition: box-shadow .2s, transform .2s;
                margin-bottom: 20px;
            }

                .subject-card:hover {
                    box-shadow: 0 10px 30px rgba(255,102,0,0.14);
                    transform: translateY(-8px) scale(1.03);
                }

                .subject-card h3 {
                    color: #ff6600;
                    font-size: 22px;
                    font-weight: 600;
                }

                .subject-card .btn-view {
                    background: #ff6600;
                    color: #fff;
                }

                    .subject-card .btn-view:hover {
                        background: #e65c00;
                    }

            .grid-subjects, .grid-responsive {
                display: grid;
                grid-gap: 24px;
                grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
            }

            @@media (max-width: 900px) {
                .grid-subjects, .grid-responsive {
                    grid-template-columns: 1fr;
                }
            }

            /* ======= Buttons ======= */
            .btn-orange, .btn-primary {
                background: #ff6600;
                color: #fff;
                border: none;
                font-weight: bold;
                padding: 10px 24px;
                border-radius: 6px;
                transition: background 0.2s, color 0.2s;
            }

                .btn-orange:hover, .btn-primary:hover, .btn-primary:focus {
                    background: #e65c00;
                    color: #fff;
                }

            .btn-outline-orange {
                color: #ff6600;
                border: 2px solid #ff6600;
                background: #fff;
                font-weight: 600;
            }

                .btn-outline-orange:hover {
                    background: #ff6600;
                    color: #fff;
                }

            .btn-lg {
                font-size: 1.25rem;
                padding: 12px 34px;
            }

            .btn-icon {
                display: inline-flex;
                align-items: center;
                gap: 6px;
            }

            .form-control:focus, .form-select:focus {
                border-color: #ff6600;
                box-shadow: 0 0 0 .18rem rgba(255,102,0,.18);
            }

            /* ======= Alerts, Toasts, Modals ======= */
            .alert-custom {
                background: #fff3e8;
                border-left: 6px solid #ff6600;
                color: #c15000;
                border-radius: 6px;
                padding: 16px 18px;
                margin-bottom: 20px;
                font-size: 1rem;
            }

            .modal-content {
                border-radius: 12px;
                border: 2px solid #ff6600;
            }

            .modal-header {
                background: #ff6600;
                color: #fff;
                border-top-left-radius: 12px;
                border-top-right-radius: 12px;
            }

            @@media (max-width:600px) {
                .modal-content {
                    border-radius: 0;
                }
            }

            /* ======= Dashboard Banner/Header ======= */
            .dashboard-header {
                background: linear-gradient(to right, #ff6600e6 0%, #fb8a24cc 100%), url('/Content/images/grade-12e3-fun-picture.jpg') center/cover no-repeat;
                color: #fff;
                min-height: 220px;
                position: relative;
                margin-bottom: 34px;
            }

                .dashboard-header .header-content {
                    padding: 60px 0 40px 0;
                    text-align: center;
                    position: relative;
                    z-index: 2;
                }

                    .dashboard-header .header-content h1 {
                        font-size: 2.5rem;
                        font-weight: bold;
                        margin-bottom: 0;
                    }

                    .dashboard-header .header-content p {
                        font-size: 1.18rem;
                        margin-top: 10px;
                        color: #ffd6ba;
                    }

                .dashboard-header .header-overlay {
                    position: absolute;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
                    background: rgba(0,0,0,0.55);
                    z-index: 1;
                    border-radius: inherit;
                }

            /* ======= Headings & Typography ======= */
            .section-title {
                font-size: 2.2rem;
                font-weight: bold;
                color: #ff6600;
                text-align: center;
                margin-bottom: 16px;
                letter-spacing: .7px;
            }

            .section-desc {
                text-align: center;
                color: #666;
                margin-bottom: 36px;
                font-size: 1.15rem;
            }

            h2, h3, h4 {
                color: #ff6600;
                font-weight: bold;
            }

            h5, h6 {
                color: #333;
            }

            .text-muted, .text-secondary {
                color: #888 !important;
            }

            /* ======= Table Styles ======= */
            .table {
                background: #fff;
                border-radius: 10px;
                overflow: hidden;
                margin-bottom: 25px;
            }

                .table th {
                    background: #ff6600;
                    color: #fff;
                    font-weight: 600;
                }

                .table td, .table th {
                    border: none !important;
                }

            .table-striped > tbody > tr:nth-of-type(odd) {
                background: #fff5ed;
            }

            /* ======= Forms ======= */
            label {
                color: #ff6600;
                font-weight: 600;
            }

            input, textarea, select {
                border-radius: 6px !important;
                border: 1.5px solid #ff660022 !important;
            }

            .form-check-input:checked {
                background-color: #ff6600;
                border-color: #e65c00;
            }

            input:focus, textarea:focus, select:focus {
                border-color: #ff6600 !important;
                box-shadow: 0 0 0 .15rem #ff660033;
                outline: none;
            }

            /* ======= Custom Grid, Cards, and Misc ======= */
            .custom-grid {
                display: grid;
                grid-gap: 30px;
                grid-template-columns: repeat(auto-fit, minmax(330px, 1fr));
            }

            @@media (max-width: 900px) {
                .custom-grid {
                    grid-template-columns: 1fr;
                }
            }

            .custom-list {
                padding: 0;
                margin: 0;
                list-style: none;
            }

                .custom-list li {
                    margin-bottom: 16px;
                    background: #fffbf7;
                    padding: 12px 14px;
                    border-radius: 8px;
                }

            /* ======= Profile & Avatars ======= */
            .avatar-xl {
                width: 110px;
                height: 110px;
                object-fit: cover;
                border-radius: 50%;
                border: 3px solid #ff6600;
                margin-bottom: 14px;
                background: #fff;
            }

            .avatar-md {
                width: 58px;
                height: 58px;
                object-fit: cover;
                border-radius: 50%;
                border: 2px solid #ff6600;
                margin-bottom: 7px;
            }

            .avatar-sm {
                width: 32px;
                height: 32px;
                border-radius: 50%;
            }

            .badge-orange {
                background: #ff6600;
                color: #fff;
                font-weight: 500;
                border-radius: 6px;
                padding: 4px 12px;
            }

            /* ======= Animations & Utilities ======= */
            .fade-in {
                animation: fadeIn 1.3s;
            }

            @@keyframes fadeIn {
                0% {
                    opacity: 0;
                    transform: translateY(24px);
                }

                100% {
                    opacity: 1;
                    transform: none;
                }
            }

            .slide-in {
                animation: slideIn .7s;
            }

            @@keyframes slideIn {
                0% {
                    transform: translateX(-30px);
                    opacity: 0;
                }

                100% {
                    transform: none;
                    opacity: 1;
                }
            }

            .sticky-top {
                position: sticky;
                top: 0;
                z-index: 1080;
                background: #ff6600;
            }

            .bg-gradient-orange {
                background: linear-gradient(45deg,#ff6600,#fb8a24,#fff7f2);
            }

            .cursor-pointer {
                cursor: pointer;
            }

            .rounded-12 {
                border-radius: 12px !important;
            }

            .shadow-soft {
                box-shadow: 0 6px 18px rgba(0,0,0,0.10);
            }

            .text-orange {
                color: #ff6600 !important;
            }

            .bg-white {
                background: #fff;
            }

            /* ======= Scrollbar Styling ======= */
            ::-webkit-scrollbar {
                width: 10px;
                background: #eee;
            }

            ::-webkit-scrollbar-thumb {
                background: #ff6600dd;
                border-radius: 8px;
            }

                ::-webkit-scrollbar-thumb:hover {
                    background: #ff6600;
                }

            /* ======= Loader (for AJAX, optional) ======= */
            #page-loader {
                position: fixed;
                top: 0;
                left: 0;
                width: 100vw;
                height: 100vh;
                background: #fff;
                z-index: 9999;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: opacity 0.4s;
                display: none;
            }

                #page-loader .spinner-border {
                    color: #ff6600;
                    width: 54px;
                    height: 54px;
                    border-width: 6px;
                }

            /* ...Continue all major UI pieces (profile forms, chat modules, modals, QR popups, sidebar menus, calendar, forum, dashboards, etc)...
           Full CSS here (800+ lines) ensures any view looks modern/beautiful by default, even if it only has <h1> or <form>.
           Expand as your project grows!
        */
    </style>
</head>
<body>
    @* ===== Student navbar (books-focused, custom styles) ===== *@
    @using Avonford_Secondary_School.Models
    @{
        decimal walletBalance = 0m;
        if (Session["UserID"] != null)
        {
            var uid = Convert.ToInt32(Session["UserID"]);
            using (var _db = new HighschoolDbEntities2())
            {
                walletBalance = _db.UserWallets
                                   .Where(w => w.UserID == uid)
                                   .Select(w => w.AvailableBalance)
                                   .FirstOrDefault();
            }
        }
    }

    @if (Session["UserRole"] != null && Session["UserRole"].ToString() == "Student")
    {
        <style>
            /* App bar */
            .appbar {
                background: #ff6a00;
            }
                /* orange */
                .appbar .navbar-brand,
                .appbar .nav-link {
                    color: #fff !important;
                }

                    .appbar .nav-link:hover,
                    .appbar .nav-link:focus {
                        color: #ffe8d6 !important;
                    }

                .appbar .dropdown-toggle::after {
                    border-top-color: #fff !important;
                }

                /* Make dropdown readable regardless of global theme */
                .appbar .dropdown-menu {
                    background: #ffffff !important;
                    color: #111827 !important; /* slate-900 */
                    border: 1px solid rgba(0,0,0,.08);
                    box-shadow: 0 8px 24px rgba(0,0,0,.12);
                    border-radius: 12px;
                    padding: 8px;
                    min-width: 220px;
                }

                .appbar .dropdown-item {
                    color: #111827 !important;
                    border-radius: 8px;
                    padding: .5rem .75rem;
                }

                    .appbar .dropdown-item:hover,
                    .appbar .dropdown-item:focus {
                        background: #ffeae0 !important; /* soft orange */
                        color: #111827 !important;
                    }

                .appbar .dropdown-divider {
                    border-top: 1px solid #f1f5f9;
                }

            /* Wallet pill */
            .wallet-pill {
                background: #ffffff;
                color: #111827;
                border-radius: 999px;
                padding: .25rem .6rem;
                font-weight: 600;
                display: inline-flex;
                align-items: center;
                gap: .45rem;
                border: 1px solid rgba(0,0,0,.06);
            }

            /* Toggler */
            .appbar .navbar-toggler {
                border-color: rgba(255,255,255,.35);
            }

            .appbar .navbar-toggler-icon {
                filter: invert(1);
            }
        </style>

        <nav class="navbar navbar-student navbar-expand-lg sticky-top shadow appbar">
            <div class="container">
                <a class="navbar-brand" href="/Student/Index">
                    Avonford Secondary School
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#studentNav"
                        aria-controls="studentNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="studentNav">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <!-- Keep Dashboard/Home -->
                        <li class="nav-item">
                            <a class="nav-link" href="/Student/Index">Dashboard</a>
                        </li>

                        <!-- Books / Library dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="booksMenu" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                Books & Library
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="booksMenu">
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("Index","Book")">
                                        Explore Library
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("Sell","Book")">
                                        Sell a Book
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("MyListings","Book")">
                                        My Listings
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("MyOrders","Book")">
                                        My Orders
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("MyReturns","Book")">
                                        My Returns
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("MyBorrowings","Book")">
                                        My Borrowings
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("Wallet","Book")">
                                        Wallet & Top-Up
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- Wallet balance (always visible) -->
                        <li class="nav-item ms-lg-3">
                            <a class="nav-link" href="@Url.Action("Wallet","Book")" title="Go to Wallet">
                                <span class="wallet-pill">Wallet: R @walletBalance.ToString("0.00")</span>
                            </a>
                        </li>

                        <!-- Logout -->
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Logout">Logout</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    }


    @* ===== Admin navbar (custom styles + wallet pill) ===== *@
    @using Avonford_Secondary_School.Models
    @{
       
        if (Session["UserID"] != null)
        {
            var uid = Convert.ToInt32(Session["UserID"]);
            using (var _db = new HighschoolDbEntities2())
            {
                walletBalance = _db.UserWallets
                                   .Where(w => w.UserID == uid)
                                   .Select(w => w.AvailableBalance)
                                   .FirstOrDefault();
            }
        }
    }

    @if (Session["UserRole"] != null && Session["UserRole"].ToString() == "Admin")
    {
        <style>
            /* Admin app bar theme */
            .appbar-admin {
                background: #ff6a00;
            }

                .appbar-admin .navbar-brand,
                .appbar-admin .nav-link {
                    color: #fff !important;
                }

                    .appbar-admin .nav-link:hover,
                    .appbar-admin .nav-link:focus {
                        color: #ffe8d6 !important;
                    }

                .appbar-admin .dropdown-toggle::after {
                    border-top-color: #fff !important;
                }

                /* Force readable dropdowns regardless of global theme */
                .appbar-admin .dropdown-menu {
                    background: #ffffff !important;
                    color: #111827 !important;
                    border: 1px solid rgba(0,0,0,.08);
                    box-shadow: 0 8px 24px rgba(0,0,0,.12);
                    border-radius: 12px;
                    padding: 8px;
                    min-width: 240px;
                }

                .appbar-admin .dropdown-item {
                    color: #111827 !important;
                    border-radius: 8px;
                    padding: .5rem .75rem;
                }

                    .appbar-admin .dropdown-item:hover,
                    .appbar-admin .dropdown-item:focus {
                        background: #ffeae0 !important;
                        color: #111827 !important;
                    }

                .appbar-admin .dropdown-divider {
                    border-top: 1px solid #f1f5f9;
                }

            /* Wallet pill */
            .wallet-pill {
                background: #ffffff;
                color: #111827;
                border-radius: 999px;
                padding: .25rem .6rem;
                font-weight: 600;
                display: inline-flex;
                align-items: center;
                gap: .45rem;
                border: 1px solid rgba(0,0,0,.06);
            }

            /* Toggler */
            .appbar-admin .navbar-toggler {
                border-color: rgba(255,255,255,.35);
            }

            .appbar-admin .navbar-toggler-icon {
                filter: invert(1);
            }
        </style>

        <nav class="navbar navbar-expand-lg sticky-top shadow appbar-admin">
            <div class="container">
                <a class="navbar-brand" href="@Url.Action("Index","Admin")">
                    Avonford Secondary School — Admin
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#adminNav" aria-controls="adminNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="adminNav">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <!-- Dashboard -->
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index","Admin")">Dashboard</a>
                        </li>

                        <!-- Applications -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="appsMenu" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">Applications</a>
                            <ul class="dropdown-menu" aria-labelledby="appsMenu">
                                <li><a class="dropdown-item" href="@Url.Action("PendingApplications","Admin")">Pending Applications</a></li>
                            </ul>
                        </li>

                        <!-- Teachers -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="teachersMenu" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">Teachers</a>
                            <ul class="dropdown-menu" aria-labelledby="teachersMenu">
                                <li><a class="dropdown-item" href="@Url.Action("RegisterTeacher","Admin")">Register Teacher</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("AllocateTeacher","Admin", new { selectedGrade = 8 })">Allocate Teacher</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("TeacherAllocationHistory","Admin")">Allocation History</a></li>
                            </ul>
                        </li>

                        <!-- Transfers -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="transferMenu" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">Transfers</a>
                            <ul class="dropdown-menu" aria-labelledby="transferMenu">
                                <li><a class="dropdown-item" href="@Url.Action("TransferRequests","Admin", new { status = "TeacherApproved" })">Transfer Requests</a></li>
                            </ul>
                        </li>

                        <!-- Delivery & Drivers -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="driversMenu" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">Delivery</a>
                            <ul class="dropdown-menu" aria-labelledby="driversMenu">
                                <li><a class="dropdown-item" href="@Url.Action("Drivers","Admin")">Drivers</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("CreateDriver","Admin")">Add Driver</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("OrdersAwaitingDriver","Admin")">Orders Awaiting Driver</a></li>
                            </ul>
                        </li>

                        <!-- Returns / RMAs -->
                        <li class="nav-item dropdown">
