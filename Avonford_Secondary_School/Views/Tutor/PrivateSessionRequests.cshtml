@model List<Avonford_Secondary_School.Models.ViewModels.PrivateSessionRequestVM>
@{
    ViewBag.Title = "Pending Private Session Requests";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container py-4">
    <h2 class="mb-3">Pending Private Session Requests</h2>
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Student</th>
                <th>Subject</th>
                <th>Start</th>
                <th>End</th>
                <th>Topic</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">No pending requests found.</td>
                </tr>
            }
            else
            {
                foreach (var req in Model)
                {
                    <tr>
                        <td>@req.StudentName</td>
                        <td>@req.SubjectName</td>
                        <td>@req.StartTime.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@req.EndTime.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@req.TopicMessage</td>
                        <td>
                            <a href="@Url.Action("ReviewSessionRequest", "Tutor", new { requestId = req.RequestID })" class="btn btn-primary btn-sm">
                                Review
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
