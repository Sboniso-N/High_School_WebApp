@model Avonford_Secondary_School.Models.ViewModels.DriverFormVM
@using (Html.BeginForm(null, null, FormMethod.Post, new { enctype = "multipart/form-data", id = "driverForm" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.DriverID)

    <div class="row">
        <div class="col-md-8">
            <div class="form-group">
                @Html.LabelFor(m => m.Name)
                @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "Full name" })
                @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
            </div>
            <div class="form-group">
                @Html.LabelFor(m => m.VehicleType)
                @Html.TextBoxFor(m => m.VehicleType, new { @class = "form-control", placeholder = "Bike, Car, Van…" })
            </div>
            <div class="form-group">
                @Html.LabelFor(m => m.Phone)
                @Html.TextBoxFor(m => m.Phone, new { @class = "form-control", placeholder = "+27…" })
                @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "text-danger" })
            </div>
            <div class="form-group">
                @Html.LabelFor(m => m.Email)
                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "name@example.com" })
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
            </div>
            <div class="row">
                <div class="col-sm-6">
                    <div class="form-group">
                        @Html.LabelFor(m => m.LicenseNo)
                        @Html.TextBoxFor(m => m.LicenseNo, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.LicenseNo, "", new { @class = "text-danger" })
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="form-group">
                        @Html.LabelFor(m => m.LicenseExpiry)
                        @Html.TextBoxFor(m => m.LicenseExpiry, "{0:yyyy-MM-dd}", new { @type = "date", @class = "form-control" })
                        <span class="help-block small">Must be a future date.</span>
                        @Html.ValidationMessageFor(m => m.LicenseExpiry, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-sm-6">
                    <div class="form-group">
                        @Html.LabelFor(m => m.MaxDailyDeliveries)
                        @Html.TextBoxFor(m => m.MaxDailyDeliveries, new { @class = "form-control", @type = "number", min = "1", max = "50" })
                    </div>
                </div>
                <div class="col-sm-6">
                    <label class="control-label" style="display:block;">Default Availability</label>
                    <label class="checkbox-inline">
                        @Html.CheckBoxFor(m => m.DefaultAvailable) Available on create/edit
                    </label>
                </div>
            </div>

            <button class="btn btn-primary" id="btnSave">
                <span class="glyphicon glyphicon-floppy-disk"></span>
                Save
            </button>
            <a class="btn btn-default" href="@Url.Action("Drivers","Admin")">Cancel</a>
        </div>

        <div class="col-md-4">
            <label>Profile Photo</label>
            <div class="well text-center" id="dropArea" style="cursor:pointer">
                <img id="preview" src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=" style="max-width:100%;height:160px;object-fit:cover;border-radius:8px;" />
                <div class="text-muted small m-t-10">Click or drop image (JPG/PNG)</div>
                @Html.TextBoxFor(m => m.Photo, new { type = "file", accept = "image/*", style = "display:none;", id = "fileInput" })
            </div>
        </div>
    </div>
}

@section scripts{
    <script>
   
    var drop = document.getElementById('dropArea');
    var input = document.getElementById('fileInput');
    var preview = document.getElementById('preview');
    drop.addEventListener('click', ()=> input.click());
    drop.addEventListener('dragover', e=>{e.preventDefault(); drop.classList.add('well-lg');});
    drop.addEventListener('dragleave', e=>{drop.classList.remove('well-lg');});
    drop.addEventListener('drop', e=>{
        e.preventDefault(); drop.classList.remove('well-lg');
        if(e.dataTransfer.files && e.dataTransfer.files[0]){ input.files = e.dataTransfer.files; showPreview(input.files[0]); }
    });
    input.addEventListener('change', function(){ if(this.files && this.files[0]) showPreview(this.files[0]); });
    function showPreview(f){
        var reader = new FileReader();
        reader.onload = function(e){ preview.src = e.target.result; preview.classList.add('flip-in'); setTimeout(()=>preview.classList.remove('flip-in'),400); };
        reader.readAsDataURL(f);
    }

    // friendly submit spinner + quick client check
    $('#driverForm').on('submit', function(){
        var exp = new Date($('#LicenseExpiry').val());
        var today = new Date(); today.setHours(0,0,0,0);
        if(exp <= today){
            alert('License expiry must be in the future.');
            return false;
        }
        $('#btnSave').prop('disabled', true).append(' <span class="glyphicon glyphicon-refresh glyphicon-refresh-animate"></span>');
    });
    </script>
    <style>
    .glyphicon-refresh-animate { -webkit-animation: spin .7s infinite linear; animation: spin .7s infinite linear; }
    @@-webkit-keyframes spin { from{-webkit-transform:rotate(0);} to{-webkit-transform:rotate(360deg);} }
    @@keyframes spin { from{transform:rotate(0);} to{transform:rotate(360deg);} }
    </style>
}
