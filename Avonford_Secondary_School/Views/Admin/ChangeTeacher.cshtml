@model Avonford_Secondary_School.Models.ViewModels.ChangeTeacherViewModel

@{
    ViewBag.Title = "Assign or Change Teacher";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #fff;
            color: #222;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .navbar-custom {
            background-color: #ff6600;
            border: none;
            border-radius: 0;
            margin-bottom: 0;
        }

            .navbar-custom .navbar-brand {
                font-size: 24px;
                font-weight: bold;
                color: #fff !important;
            }

            .navbar-custom .navbar-nav > li > a {
                color: #fff !important;
                font-size: 16px;
            }

                .navbar-custom .navbar-nav > li > a:hover {
                    color: #222 !important;
                }

        .admin-header {
            background-image: url('../../Content/images/grade-12e3-fun-picture.jpg');
            background-size: cover;
            background-position: center;
            height: 250px;
            position: relative;
            margin-bottom: 30px;
        }

            .admin-header .overlay {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background-color: rgba(0,0,0,0.5);
            }

            .admin-header .text {
                position: relative;
                z-index: 1;
                color: white;
                text-align: center;
                padding-top: 80px;
            }

                .admin-header .text h1 {
                    font-size: 38px;
                    font-weight: bold;
                }

        .content-section {
            padding: 40px 20px;
        }

        .form-control {
            margin-bottom: 20px;
        }

        .btn-primary {
            background-color: #ff6600;
            border-color: #ff6600;
        }

            .btn-primary:hover {
                background-color: #e65c00;
                border-color: #e65c00;
            }

        .panel {
            padding: 20px;
            border: 1px solid #ddd;
            background-color: #f9f9f9;
            border-radius: 6px;
        }

        .info-note {
            margin-bottom: 15px;
            color: #555;
            font-style: italic;
        }
    </style>
</head>
<body>
    <!-- Admin Navbar -->
    <nav class="navbar navbar-custom">
        <div class="container">
            <div class="navbar-header">
                <a class="navbar-brand" href="/Admin/Index">Avonford Admin Panel</a>
            </div>
            <ul class="nav navbar-nav navbar-right">
                <li><a href="/Admin/PendingApplications">Pending Applications</a></li>
                <li><a href="/Admin/RegisterTeacher">Register Teacher</a></li>
                <li><a href="/Admin/AllocateTeacher">Allocate Teachers</a></li>
                <li><a href="/Account/Logout">Logout</a></li>
            </ul>
        </div>
    </nav>

    <!-- Header -->
    <div class="admin-header">
        <div class="overlay"></div>
        <div class="text">
            <h1>Assign or Change Teacher</h1>
        </div>
    </div>

    <!-- Main Form -->
    <div class="container content-section">
        <div class="panel">
            @using (Html.BeginForm("ChangeTeacher", "Admin", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                @Html.HiddenFor(m => m.GradeSubjectTeacherID)
                @Html.HiddenFor(m => m.GradeID)
                @Html.HiddenFor(m => m.StreamID)
                @Html.HiddenFor(m => m.SubjectID)

                <p><strong>Subject:</strong> @Model.SubjectName</p>
                <p>
                    <strong>Grade:</strong> @Model.GradeID
                    @if (!string.IsNullOrEmpty(Model.StreamName))
                    {
                        @(", Stream: " + Model.StreamName)
                    }
                </p>

                <p class="info-note">
                    Only teachers qualified to teach "@Model.SubjectName" appear below.
                </p>

                <div class="form-group">
                    <label>Select Teacher:</label>
                    @Html.DropDownListFor(m => m.SelectedTeacherID, Model.TeacherList, "No Teacher", new { @class = "form-control" })
                </div>

                <input type="submit" value="Save" class="btn btn-primary" />
            }
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
</body>
</html>
