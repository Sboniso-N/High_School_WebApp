@model Avonford_Secondary_School.Models.ViewModels.AdminTransferRequestReviewVM
@{
    ViewBag.Title = "Finalize Stream Transfer";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var statusList = new[] { "Submitted", "PendingTeacher", "TeacherApproved", "TeacherRejected", "PendingAdmin", "AdminApproved", "AdminRejected", "Cancelled" };
}
@section Styles{
    <style>
        .stepper {
            display: flex;
            align-items: center;
            margin-bottom: 2rem;
        }

        .stepper-step {
            flex: 1;
            text-align: center;
            position: relative;
        }

        .stepper-circle {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            border: 3px solid #ddd;
            display: inline-block;
            font-weight: bold;
            background: #fff;
            color: #aaa;
            line-height: 32px;
        }

        .stepper-step.active .stepper-circle {
            border-color: #007bff;
            color: #007bff;
        }

        .stepper-step.completed .stepper-circle {
            border-color: #28a745;
            background: #28a745;
            color: #fff;
        }

        .stepper-label {
            margin-top: 8px;
            font-size: 13px;
        }

        .stepper-bar {
            position: absolute;
            top: 15px;
            left: 50%;
            width: 100%;
            height: 4px;
            z-index: -1;
            background: #ddd;
        }

        .stepper-step:last-child .stepper-bar {
            display: none;
        }

        .stepper-step.completed ~ .stepper-step .stepper-bar {
            background: #28a745;
        }

        .badge-danger {
            background: #dc3545;
        }

        .badge-success {
            background: #28a745;
        }

        .badge-info {
            background: #17a2b8;
        }

        .table-hover tbody tr:hover {
            background: #f6fafb;
        }

        .doc-preview-link {
            color: #E53935;
            font-weight: bold;
        }

        .audit-timeline {
            border-left: 3px solid #007bff;
            padding-left: 1rem;
            margin-left: 1.2rem;
        }

        .audit-entry {
            margin-bottom: .9rem;
        }

        .audit-dot {
            width: 13px;
            height: 13px;
            border-radius: 50%;
            background: #007bff;
            display: inline-block;
            margin-right: 8px;
        }

        .timetable-preview {
            background: #f3f6fa;
            border: 1px dashed #007bff;
            border-radius: 6px;
            padding: 12px 18px;
            margin-bottom: 1.5rem;
        }

        .warning-capacity {
            color: #dc3545;
            font-weight: bold;
        }

        .conflict {
            color: #e55353;
            font-weight: bold;
        }
    </style>
}

<div class="container my-5">
    <h2 class="mb-4 text-primary"><i class="fas fa-user-cog"></i> Admin Finalization: Stream Transfer</h2>
    <div class="mb-3">
        <span class="badge badge-secondary p-2">Status: <b>@Model.Status</b></span>
    </div>

    <!-- Stepper/Progress bar -->
    <div class="stepper mb-4">
        @{
            int stepIndex = Array.IndexOf(statusList, Model.Status);
            for (int i = 0; i < statusList.Length; i++)
            {
                var cls = i < stepIndex ? "completed" : i == stepIndex ? "active" : "";
            }
        }
        @for (int i = 0; i < statusList.Length; i++)
        {
            var stepLabel = statusList[i];
            var cls = i < Array.IndexOf(statusList, Model.Status) ? "completed" : i == Array.IndexOf(statusList, Model.Status) ? "active" : "";
            <div class="stepper-step @cls">
                <div class="stepper-circle">@((i+1).ToString())</div>
                <div class="stepper-label">@stepLabel.Replace("Teacher", "Teacher<br/>")</div>
                <div class="stepper-bar"></div>
            </div>
        }
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-info text-white"><b>Student & Request Details</b></div>
        <div class="card-body">
            <b>Student:</b> @Model.StudentName <span class="text-muted">(ID: @Model.StudentID)</span><br />
            <b>Current:</b> Grade @Model.OldGrade (<b>@Model.OldStream</b>)<br />
            <b>Requested:</b> Grade @Model.NewGrade (<b>@Model.NewStream</b>)<br />
            <b>Justification:</b>
            <div class="alert alert-light border p-2 mb-2">@Model.Justification</div>
            <b>Teacher Comment:</b>
            <div class="alert alert-light border p-2 mb-2">@Model.TeacherComment</div>
            @if (Model.AttachmentFileID != null)
            {
                <b>Attachment:</b>
                <a href="@Url.Action("PreviewTransferAttachment", "Admin", new { fileId = Model.AttachmentFileID })" target="_blank" class="doc-preview-link">
                    <i class="fas fa-file-pdf"></i> View PDF
                </a>
            }
        </div>
    </div>

    <!-- Capacity/Seat Checker -->
    <div class="alert @(Model.IsStreamFull ? "alert-danger" : "alert-success")">
        <i class="fas fa-users"></i>
        <b>Target Stream Capacity:</b>
        @Model.CurrentSeatCount / @Model.MaxSeats students
        @if (Model.IsStreamFull)
        {
            <span class="warning-capacity"><i class="fas fa-exclamation-triangle"></i> No more seats! Approving is blocked.</span>
        }
        else if (Model.MaxSeats - Model.CurrentSeatCount <= 3)
        {
            <span class="badge badge-warning ml-2">Warning: Nearly full</span>
        }
    </div>

    <!-- Schedule Conflict Checker -->
    @if (Model.ConflictingSubjects != null && Model.ConflictingSubjects.Any())
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i>
            <b>Conflict detected:</b> The following subjects are duplicated/overlapping:<br />
            <ul>
                @foreach (var c in Model.ConflictingSubjects)
                {
                    <li class="conflict">@c</li>
                }
            </ul>
        </div>
    }

    <!-- Timetable Impact Preview -->
    <div class="timetable-preview mb-4">
        <h6 class="mb-2"><i class="fas fa-calendar-alt text-primary"></i> Timetable Impact Preview</h6>
        @Html.Raw(Model.TimetableImpactPreviewHtml)
    </div>

    <!-- Admin Finalization Panel -->
    @using (Html.BeginForm("ReviewTransferRequest", "Admin", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.TransferRequestID)
        <div class="card shadow mb-4">
            <div class="card-header bg-primary text-white"><b>Finalize Decision</b></div>
            <div class="card-body">
                <div class="form-row mb-3">
                    <div class="col-md-6 mb-2">
                        <label>
                            <input type="radio" name="Action" value="Approve" id="actionApprove" @(Model.Action == "Approve" ? "checked" : "") @(Model.IsStreamFull ? "disabled" : "") />
                            <span class="ml-1 text-success"><i class="fas fa-thumbs-up"></i> Approve & Update Schedule</span>
                        </label>
                    </div>
                    <div class="col-md-6 mb-2">
                        <label>
                            <input type="radio" name="Action" value="Reject" id="actionReject" @(Model.Action == "Reject" ? "checked" : "") />
                            <span class="ml-1 text-danger"><i class="fas fa-thumbs-down"></i> Reject</span>
                        </label>
                    </div>
                </div>
                <div class="mb-2" id="approveMsg" style="display:none;">
                    <i class="fas fa-info-circle text-info"></i> Approving will auto-update the student's schedule. Please provide a brief comment.
                </div>
                <div class="mb-2" id="rejectMsg" style="display:none;">
                    <i class="fas fa-exclamation-triangle text-danger"></i> Please provide a clear reason for rejection.
                </div>
                <textarea class="form-control mb-2" id="AdminComment" name="AdminComment" rows="4"
                          maxlength="500"
                          placeholder="Add your comments or reasons here...">@Model.AdminComment</textarea>
                @Html.ValidationMessageFor(m => m.AdminComment, "", new { @class = "text-danger" })
                <div class="mt-3 text-center">
                    <button type="submit" class="btn btn-lg btn-success px-4" id="submitBtn" @(Model.IsStreamFull ? "disabled" : "")>
                        <i class="fas fa-check"></i> Submit Decision
                    </button>
                    <a href="@Url.Action("TransferRequests", "Admin")" class="btn btn-secondary ml-3">Back to Requests</a>
                </div>
            </div>
        </div>
    }

    <!-- Audit Log Timeline -->
    <div class="card shadow-sm mt-4">
        <div class="card-header bg-dark text-white"><i class="fas fa-history"></i> Audit Trail</div>
        <div class="card-body audit-timeline">
            @if (Model.AuditTrail.Any())
            {
                foreach (var log in Model.AuditTrail)
                {
                    <div class="audit-entry">
                        <span class="audit-dot"></span>
                        <b>@log.Action</b> by <span class="text-primary">@log.PerformedByRole</span>
                        <span class="text-muted small">(@log.PerformedByName)</span> -
                        <span class="text-muted small">@log.ActionDate.ToString("yyyy-MM-dd HH:mm")</span>
                        @if (!string.IsNullOrWhiteSpace(log.Comment))
                        {
                            <div class="text-muted small ml-4">"@log.Comment"</div>
                        }
                    </div>
                }
            }
            else
            {
                <span class="text-muted">No audit events logged yet.</span>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleMsg() {
            $("#approveMsg, #rejectMsg").hide();
            if ($("#actionApprove").is(":checked")) $("#approveMsg").show();
            if ($("#actionReject").is(":checked")) $("#rejectMsg").show();
        }
        $(function () {
            $("input[name=Action]").on("change", toggleMsg);
            toggleMsg();
            // Prevent submit if stream is full
            if ('@Model.IsStreamFull' === 'True') {
                $("#submitBtn").prop("disabled", true);
                $("#actionApprove").prop("disabled", true);
            }
        });
    </script>
}
