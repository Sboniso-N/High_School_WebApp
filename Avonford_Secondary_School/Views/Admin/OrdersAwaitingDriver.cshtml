@model Avonford_Secondary_School.Models.ViewModels.OrdersAwaitingDriverVM
@{
    ViewBag.Title = "Orders Awaiting Driver";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .order-row { transition: background .2s ease; }
    .order-row:hover { background: #fcfcfd; }
    .thumb { width:64px; height:64px; object-fit:cover; border-radius:6px; background:#f1f3f5; }
    .fade-in { animation: fadeIn .35s ease; }
    @@keyframes fadeIn { from{opacity:.3; transform: translateY(4px);} to{opacity:1; transform:none;} }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Orders Awaiting Driver</h2>
    <a class="btn btn-default" href="@Url.Action("Drivers","Admin")">Manage Drivers</a>
</div>

<div class="row mb-3">
    <div class="col-sm-6">
        <input id="q" type="text" class="form-control" placeholder="Filter by book or buyer…">
    </div>
</div>

<div class="table-responsive fade-in">
    <table class="table table-striped table-hover" id="ordersTbl">
        <thead>
            <tr>
                <th>Order #</th>
                <th>Book</th>
                <th>Buyer</th>
                <th>Address</th>
                <th>Delivery Fee</th>
                <th>Order Date</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in Model.Orders)
            {
                <tr class="order-row">
                    <td class="v-middle"><strong>@o.OrderID</strong></td>
                    <td class="v-middle">
                        <div class="media">
                            <div class="media-left">
                                <img class="thumb" src="@(o.MainImageBase64 != null ? ("data:image/*;base64," + o.MainImageBase64) : "data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=")" />
                            </div>
                            <div class="media-body">
                                <div class="m-b-0">@o.BookTitle</div>
                                <div class="text-muted small">@o.Condition</div>
                            </div>
                        </div>
                    </td>
                    <td class="v-middle">
                        <div>@o.BuyerName</div>
                        <div class="text-muted small">@o.BuyerEmail</div>
                    </td>
                    <td class="v-middle" style="max-width:340px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="@o.DeliveryAddress">
                        @o.DeliveryAddress
                    </td>
                    <td class="v-middle">R @o.DeliveryFee.ToString("0.00")</td>
                    <td class="v-middle">@o.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="v-middle text-right">
                        <a class="btn btn-success" href="@Url.Action("AssignDriver","Admin", new { orderId = o.OrderID })">
                            <span class="glyphicon glyphicon-send"></span> Assign
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section scripts{
    <script>
    $('#q').on('input', function(){
       var term = $(this).val().toLowerCase();
       $('#ordersTbl tbody tr').each(function(){
          var txt = $(this).text().toLowerCase();
          $(this).toggle(txt.indexOf(term) !== -1);
       });
    });
    </script>
}
