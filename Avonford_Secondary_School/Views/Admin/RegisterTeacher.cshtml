@model Avonford_Secondary_School.Models.ViewModels.RegisterTeacherViewModel

@{
    ViewBag.Title = "Register New Teacher";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css" />
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #fff;
            color: #222;
            margin: 0;
            padding: 0;
        }

        .navbar-custom {
            background-color: #ff6600;
            border: none;
            border-radius: 0;
            margin-bottom: 0;
        }

            .navbar-custom .navbar-brand {
                font-size: 24px;
                font-weight: bold;
                color: #fff !important;
            }

            .navbar-custom .navbar-nav > li > a {
                color: #fff !important;
                font-size: 16px;
            }

                .navbar-custom .navbar-nav > li > a:hover {
                    color: #222 !important;
                }

        .form-section {
            background-color: #f9f9f9;
            border: 1px solid #ddd;
            border-radius: 6px;
            padding: 30px;
            margin-top: 40px;
            margin-bottom: 60px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        h2 {
            color: #ff6600;
            text-align: center;
            margin-top: 40px;
            font-weight: bold;
        }

        .btn-primary {
            background-color: #ff6600;
            border-color: #ff6600;
        }

            .btn-primary:hover {
                background-color: #e65c00;
                border-color: #e65c00;
            }
    </style>
</head>
<body>

    <!-- Admin Navigation Bar -->
    <nav class="navbar navbar-custom">
        <div class="container">
            <div class="navbar-header">
                <a class="navbar-brand" href="/Admin/Index">Avonford Admin Panel</a>
            </div>
            <ul class="nav navbar-nav navbar-right">
                <li><a href="/Admin/PendingApplications">Pending Applications</a></li>
                <li><a href="/Admin/RegisterTeacher">Register Teacher</a></li>
                <li><a href="/Admin/AllocateTeacher">Allocate Teachers</a></li>
                <li><a href="/Account/Logout">Logout</a></li>
            </ul>
        </div>
    </nav>

    <!-- Page Content -->
    <div class="container form-section">
        <h2>Register New Teacher</h2>

        @using (Html.BeginForm("RegisterTeacher", "Admin", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()

            <div class="form-group">
                @Html.LabelFor(m => m.FirstName, new { @class = "control-label" })
                @Html.TextBoxFor(m => m.FirstName, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.LastName, new { @class = "control-label" })
                @Html.TextBoxFor(m => m.LastName, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.Email, new { @class = "control-label" })
                @Html.TextBoxFor(m => m.Email, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.ContactNumber, new { @class = "control-label" })
                @Html.TextBoxFor(m => m.ContactNumber, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.ContactNumber, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.ProfilePicture, new { @class = "control-label" })
                <input type="file" name="ProfilePicture" />
                @Html.ValidationMessageFor(m => m.ProfilePicture, "", new { @class = "text-danger" })
            </div>

            <!-- New Subject Fields -->
            <div class="form-group">
                @Html.LabelFor(m => m.SubjectID1, new { @class = "control-label" })
                @Html.DropDownListFor(m => m.SubjectID1, Model.AvailableSubjects, "Select Primary Subject", new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.SubjectID1, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.SubjectID2, new { @class = "control-label" })
                @Html.DropDownListFor(m => m.SubjectID2, Model.AvailableSubjects, "Select Secondary Subject (Optional)", new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.SubjectID2, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.SubjectID3, new { @class = "control-label" })
                @Html.DropDownListFor(m => m.SubjectID3, Model.AvailableSubjects, "Select Tertiary Subject (Optional)", new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.SubjectID3, "", new { @class = "text-danger" })
            </div>

            <div class="text-center">
                <input type="submit" value="Register" class="btn btn-primary btn-lg" />
            </div>
        }

        @section Scripts {
            @Scripts.Render("~/bundles/jqueryval")
        }
    </div>

    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
</body>
</html>
