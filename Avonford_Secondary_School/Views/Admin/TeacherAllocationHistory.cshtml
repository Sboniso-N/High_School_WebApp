@model Avonford_Secondary_School.Models.ViewModels.TeacherAllocationHistoryViewModel

@{
    ViewBag.Title = "Teacher Allocation History";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #fff;
            color: #222;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .navbar-custom {
            background-color: #ff6600;
            border: none;
            border-radius: 0;
            margin-bottom: 0;
        }

            .navbar-custom .navbar-brand {
                font-size: 24px;
                font-weight: bold;
                color: #fff !important;
            }

            .navbar-custom .navbar-nav > li > a {
                color: #fff !important;
                font-size: 16px;
            }

                .navbar-custom .navbar-nav > li > a:hover {
                    color: #222 !important;
                }

        .admin-header {
            background-image: url('../../Content/images/grade-12e3-fun-picture.jpg');
            background-size: cover;
            background-position: center;
            height: 250px;
            position: relative;
            margin-bottom: 30px;
        }

            .admin-header .overlay {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background-color: rgba(0,0,0,0.5);
            }

            .admin-header .text {
                position: relative;
                z-index: 1;
                color: white;
                text-align: center;
                padding-top: 80px;
            }

                .admin-header .text h1 {
                    font-size: 38px;
                    font-weight: bold;
                }

        .content-section {
            padding: 40px 20px;
        }

        table {
            background-color: #f9f9f9;
        }

        th, td {
            text-align: center;
            vertical-align: middle;
        }

        .table-bordered {
            border: 1px solid #ddd;
        }
    </style>
</head>
<body>
    <!-- Admin Navbar -->
    <nav class="navbar navbar-custom">
        <div class="container">
            <div class="navbar-header">
                <a class="navbar-brand" href="/Admin/Index">Avonford Admin Panel</a>
            </div>
            <ul class="nav navbar-nav navbar-right">
                <li><a href="/Admin/PendingApplications">Pending Applications</a></li>
                <li><a href="/Admin/RegisterTeacher">Register Teacher</a></li>
                <li><a href="/Admin/AllocateTeacher">Allocate Teachers</a></li>
                <li><a href="/Account/Logout">Logout</a></li>
            </ul>
        </div>
    </nav>

    <!-- Header Section -->
    <div class="admin-header">
        <div class="overlay"></div>
        <div class="text">
            <h1>Teacher Allocation History</h1>
        </div>
    </div>

    <!-- Main Content Section -->
    <div class="container content-section">
        <h2 class="text-center" style="color:#ff6600; font-weight:bold;">Allocation History</h2>
        @if (Model.HistoryItems != null && Model.HistoryItems.Count > 0)
        {
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Teacher Name</th>
                        <th>Grade</th>
                        <th>Stream</th>
                        <th>Subject</th>
                        <th>Allocated On</th>
                        <th>Allocated By</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.HistoryItems)
                    {
                        <tr>
                            <td>@item.HistoryID</td>
                            <td>@item.TeacherName</td>
                            <td>@item.GradeName</td>
                            <td>@item.StreamName</td>
                            <td>@item.SubjectName</td>
                            <td>@item.AllocationDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@item.AllocatedByName</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-center">No allocation history available.</p>
        }
    </div>

    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
</body>
</html>
