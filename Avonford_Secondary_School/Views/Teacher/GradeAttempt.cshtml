@model Avonford_Secondary_School.Models.ViewModels.AssessmentGradingViewModel

@{
    ViewBag.Title = "Grade Attempt for " + Model.AssessmentName;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css" />
<style>
    body {
        background-color: #fff;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: #222;
    }

    .navbar-custom {
        background-color: #ff6600;
        border: none;
        border-radius: 0;
        margin-bottom: 0;
    }

        .navbar-custom .navbar-brand,
        .navbar-custom .navbar-nav > li > a {
            color: #fff !important;
            font-weight: bold;
        }

            .navbar-custom .navbar-nav > li > a:hover {
                color: #222 !important;
            }

    h2 {
        color: #ff6600;
        margin-top: 30px;
        margin-bottom: 20px;
        text-align: center;
    }

    .grading-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 20px;
        background-color: #f9f9f9;
        border: 2px solid #ddd;
        border-radius: 10px;
    }

    .panel-default {
        border: 1px solid #ddd;
        border-radius: 5px;
        margin-bottom: 20px;
    }

    .panel-heading {
        background-color: #ff6600;
        color: white;
        font-weight: bold;
        font-size: 16px;
    }

    .btn-primary {
        background-color: #ff6600;
        border-color: #e65c00;
        font-weight: bold;
    }

        .btn-primary:hover {
            background-color: #e65c00;
        }

    label {
        font-weight: bold;
    }

    .form-control {
        border-radius: 4px;
    }
    /* Styling for live score display */
    .score-summary {
        font-size: 18px;
        font-weight: bold;
        text-align: center;
        margin-top: 20px;
    }
</style>

<nav class="navbar navbar-custom">
    <div class="container-fluid">
        <div class="navbar-header">
            <a class="navbar-brand" href="/Teacher/Index">Avonford - Teacher</a>
        </div>
        <ul class="nav navbar-nav navbar-right">
            <li><a href="/Teacher/Index">Dashboard</a></li>
            <li><a href="/Teacher/CreateAssessment">Create Assessment</a></li>
            <li><a href="/Teacher/GradeAssessments">Grade Assessments</a></li>
            <li><a href="/Account/Logout">Logout</a></li>
        </ul>
    </div>
</nav>

<div class="container grading-container">
    <h2>Grade Attempt for: @Model.AssessmentName</h2>
    <p><strong>Student:</strong> @Model.StudentName</p>

    @using (Html.BeginForm("GradeAttempt", "Teacher", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.AttemptID)
        @Html.HiddenFor(m => m.AssessmentID)

        for (int i = 0; i < Model.GradingQuestions.Count; i++)
        {
            <div class="panel panel-default">
                <div class="panel-heading">
                    <strong>Question @(i + 1):</strong> @Model.GradingQuestions[i].QuestionText
                </div>
                <div class="panel-body">
                    @if (Model.GradingQuestions[i].QuestionType == "MCQ")
                    {
                        <p><strong>A:</strong> @Model.GradingQuestions[i].OptionA</p>
                        <p><strong>B:</strong> @Model.GradingQuestions[i].OptionB</p>
                        <p><strong>C:</strong> @Model.GradingQuestions[i].OptionC</p>
                        <p><strong>D:</strong> @Model.GradingQuestions[i].OptionD</p>
                    }

                    <div class="form-group">
                        <label>Student Answer:</label>
                        <div class="form-control">@Model.GradingQuestions[i].StudentAnswer</div>
                    </div>

                    <div class="form-group">
                        <label>
                            @Html.CheckBoxFor(m => m.GradingQuestions[i].IsCorrect, new { @class = "is-correct-checkbox" })
                            Mark as Correct
                        </label>
                    </div>

                    @Html.HiddenFor(m => m.GradingQuestions[i].QuestionID)
                    @Html.HiddenFor(m => m.GradingQuestions[i].QuestionType)
                </div>
            </div>
        }

        <!-- Live Score Display -->
        <div class="score-summary">
            Final Score: <span id="finalScore">0</span> / <span id="totalQuestions">@Model.GradingQuestions.Count</span>
        </div>

        <div class="text-center">
            <input type="submit" value="Submit Grades" class="btn btn-primary btn-lg" />
        </div>
    }
</div>

<script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
<script type="text/javascript">
    $(document).ready(function () {
        // Function to calculate the total score live.
        function updateFinalScore() {
            var score = 0;
            $(".is-correct-checkbox").each(function () {
                if ($(this).is(":checked")) {
                    score += 1;
                }
            });
            $("#finalScore").text(score);
        }
        // Bind the change event on all checkboxes.
        $(".is-correct-checkbox").change(function () {
            updateFinalScore();
        });
        // Initial update.
        updateFinalScore();
    });
</script>
