@model Avonford_Secondary_School.Models.ViewModels.GradeAssessmentsViewModel

@{
    ViewBag.Title = "Grade Assessments";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Teacher Navigation Bar -->
<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css" />
<nav class="navbar navbar-custom" style="background-color: #ff6600; border-radius: 0;">
    <div class="container-fluid">
        <div class="navbar-header">
            <a class="navbar-brand" href="/Teacher/Index" style="color: white;">Avonford Secondary - Teacher</a>
        </div>
        <ul class="nav navbar-nav navbar-right">
            <li><a href="/Teacher/Index" style="color: white;">Dashboard</a></li>
            <li><a href="/Teacher/CreateAssessment" style="color: white;">Create Assessment</a></li>
            <li><a href="/Teacher/GradeAssessments" style="color: white;">Grade Assessments</a></li>
            <li><a href="/Account/Logout" style="color: white;">Logout</a></li>
        </ul>
    </div>
</nav>

<!-- Page Styling -->
<style>
    body {
        font-family: 'Segoe UI', sans-serif;
        background-color: #fff;
        color: #222;
    }

    h2 {
        color: #ff6600;
        margin-top: 40px;
        text-align: center;
        margin-bottom: 30px;
    }

    .table-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 30px;
        background-color: #f9f9f9;
        border: 2px solid #ddd;
        border-radius: 10px;
    }

    .table thead {
        background-color: #ff6600;
        color: white;
    }

    .table-striped > tbody > tr:nth-child(odd) {
        background-color: #f2f2f2;
    }

    .btn-primary {
        background-color: #ff6600;
        border-color: #e65c00;
    }

        .btn-primary:hover {
            background-color: #e65c00;
        }
</style>

<div class="container table-container">
    <h2>Assessments for @Model.SubjectName</h2>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Assessment Name</th>
                <th>Type</th>
                <th>Date</th>
                <th>Time</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var assessment in Model.Assessments)
            {
                <tr>
                    <td>@assessment.AssessmentName</td>
                    <td>@assessment.AssessmentType</td>
                    <td>@assessment.AssessmentDate.ToString("yyyy-MM-dd")</td>
                    <td>@assessment.StartTime.ToString(@"hh\:mm") - @assessment.EndTime.ToString(@"hh\:mm")</td>
                    <td>
                        @Html.ActionLink("View Attempts", "ViewAttempts", "Teacher", new { assessmentId = assessment.AssessmentID }, new { @class = "btn btn-primary btn-sm" })
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
