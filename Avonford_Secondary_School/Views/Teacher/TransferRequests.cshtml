@model List<Avonford_Secondary_School.Models.ViewModels.TeacherTransferRequestListItemVM>
@{
    ViewBag.Title = "Stream Transfer Requests";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var filter = (ViewBag.Filter ?? "pending").ToString();
}

<style>
    .navbar-custom {
        background-color: #ff6600;
        border: none;
        border-radius: 0;
        margin-bottom: 0;
    }

        .navbar-custom .navbar-brand {
            font-size: 24px;
            font-weight: bold;
            color: #fff !important;
        }

        .navbar-custom .navbar-nav > li > a {
            color: #fff !important;
            font-size: 16px;
        }

            .navbar-custom .navbar-nav > li > a:hover {
                color: #222 !important;
            }
</style>
<!-- Nav Bar -->
<nav class="navbar navbar-custom">
    <div class="container">
        <div class="navbar-header">
            <a class="navbar-brand" href="/Teacher/Index">Avonford Secondary School</a>
        </div>
        <div class="collapse navbar-collapse" id="teacherNav">
            <ul class="nav navbar-nav navbar-right">
                <li><a href="/Teacher/Index">Dashboard</a></li>
                <li><a href="/Teacher/CreateAssessment">Schedule Assessment</a></li>
                <li><a href="/Teacher/GradeAssessments">Grade Assessments</a></li>
                <li><a href="/Teacher/TransferRequests">Student Tranfer Requests</a></li>
                <li><a href="/Account/Logout">Logout</a></li>
            </ul>
        </div>
    </div>
</nav>


<div class="container my-5">
    <h2 class="mb-4 text-primary"><i class="fas fa-exchange-alt"></i> Stream Transfer Requests</h2>
    <div class="mb-3">
        <a href="@Url.Action("TransferRequests", new { filter = "pending" })"
           class="btn btn-outline-primary @(filter == "pending" ? "active" : "") mr-2">
            <i class="fas fa-clock"></i> Pending
        </a>
        <a href="@Url.Action("TransferRequests", new { filter = "processed" })"
           class="btn btn-outline-secondary @(filter == "processed" ? "active" : "")">
            <i class="fas fa-check"></i> Processed
        </a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> No transfer requests found for this filter.
        </div>
    }
    else
    {
        <table class="table table-bordered table-hover shadow-sm bg-white">
            <thead class="thead-light">
                <tr>
                    <th>Student</th>
                    <th>From</th>
                    <th>To</th>
                    <th>Submitted</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>
                            <span class="font-weight-bold">@r.StudentName</span>
                            <div class="text-muted small">ID: @r.StudentID</div>
                        </td>
                        <td>
                            Grade @r.OldGrade <span class="badge badge-secondary">@r.OldStream</span>
                        </td>
                        <td>
                            Grade @r.NewGrade <span class="badge badge-primary">@r.NewStream</span>
                        </td>
                        <td>@r.SubmittedDate.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @if (r.Status == "PendingTeacher")
                            {
                                <span class="badge badge-warning"><i class="fas fa-clock"></i> Pending</span>
                            }
                            else if (r.Status == "TeacherApproved")
                            {
                                <span class="badge badge-success"><i class="fas fa-thumbs-up"></i> Approved</span>
                            }
                            else if (r.Status == "TeacherRejected")
                            {
                                <span class="badge badge-danger"><i class="fas fa-thumbs-down"></i> Rejected</span>
                            }
                            else
                            {
                                <span class="badge badge-secondary">@r.Status</span>
                            }
                        </td>
                        <td>
                            <a href="@Url.Action("ReviewTransferRequest", "Teacher", new { id = r.TransferRequestID })"
                               class="btn btn-sm btn-outline-info">
                                <i class="fas fa-eye"></i> Review
                                @if (r.ActionNeeded)
                                {
                                    <span class="badge badge-danger ml-1">Action</span>
                                }
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
