@{
    ViewBag.Title = "Payment Successful";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title</title>
    <link href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: #f4f4f4;
            padding-top: 70px;
        }

        .navbar {
            background-color: #222;
            border: none;
            border-radius: 0;
            margin-bottom: 40px;
        }

        .navbar-brand {
            color: #fff !important;
            font-weight: bold;
        }

        .navbar-nav > li > a {
            color: white !important;
            font-weight: bold;
        }

            .navbar-nav > li > a:hover {
                background-color: #ff6600 !important;
                color: #fff !important;
            }

        .container {
            max-width: 700px;
            margin: auto;
            background: #fff;
            padding: 30px 40px;
            border-radius: 8px;
            box-shadow: 0 0 30px rgba(0,0,0,0.1);
        }

        h2 {
            color: #28a745;
            margin-bottom: 25px;
        }

        .alert-success {
            padding: 15px;
            font-size: 16px;
            border-radius: 5px;
            background-color: #dff0d8;
            color: #3c763d;
            border: 1px solid #d6e9c6;
        }

        .btn-primary {
            background-color: #ff6600;
            border-color: #ff6600;
            font-weight: bold;
            font-size: 16px;
        }

            .btn-primary:hover {
                background-color: #e65c00;
                border-color: #e65c00;
            }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-inverse navbar-fixed-top">
        <div class="container">
            <div class="navbar-header">
                <a class="navbar-brand" href="#">Avonford Secondary</a>
            </div>
            <ul class="nav navbar-nav navbar-right">
                <li>@Html.ActionLink("Logout", "Logout", "Account")</li>
            </ul>
        </div>
    </nav>

    <div class="container">
        <h2>Payment Successful</h2>

        <div class="alert alert-success">
            Thank you for your payment! Your account is now active.
        </div>

        <p>
            <a href="@Url.Action("Index", "Student")" class="btn btn-primary">
                Go to Home
            </a>
        </p>
    </div>
</body>
</html>
