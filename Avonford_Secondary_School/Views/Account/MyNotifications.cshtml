@model List<Avonford_Secondary_School.Models.ViewModels.NotificationVM>
@{
    ViewBag.Title = "My Notifications";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.3.0/css/bootstrap.min.css" />

<div class="container py-4">
    <h2>My Notifications</h2>
    <hr />
    <div class="list-group" id="notificationList">
        @if (!Model.Any())
        {
            <div class="alert alert-info">You have no notifications.</div>
        }
        else
        {
            foreach (var note in Model)
            {
                <div class="list-group-item @(!note.IsRead ? "list-group-item-warning" : "")" data-id="@note.NotificationID">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-1">@note.Title</h5>
                            <small class="text-muted">@note.CreatedDate.ToString("yyyy-MM-dd HH:mm")</small>
                        </div>
                        @if (!note.IsRead)
                        {
                            <span class="badge bg-warning text-dark">New</span>
                        }
                    </div>
                    <p class="mb-1">@Html.Raw(note.Message.Replace(Environment.NewLine, "<br/>"))</p>
                    @if (note.RelatedSessionID != null)
                    {
                        <a href="@Url.Action("SessionDetail", "Student", new { sessionId = note.RelatedSessionID })" class="btn btn-sm btn-outline-primary mt-2">View Session</a>
                    }
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        // Optionally, add a script to highlight new notifications briefly, then fade the badge
        $(function () {
            setTimeout(function () {
                $(".badge.bg-warning").fadeOut(1500);
            }, 3500);
        });
    </script>
}
