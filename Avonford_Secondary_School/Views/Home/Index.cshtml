    <!-- Bootstrap CSS from CDN -->
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">
    <!-- Custom CSS -->
    <style>
        /* Theme: Orange, Light Black, and White */
        body {
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            background-color: #fff;
            color: #333;
            margin: 0;
            padding: 0;
        }
        /* Navigation */
        .navbar-custom {
            background-color: #ff6600;
            border: none;
        }

            .navbar-custom .navbar-brand,
            .navbar-custom .navbar-nav > li > a {
                color: #fff;
            }

                .navbar-custom .navbar-nav > li > a:hover {
                    color: #000;
                }
        /* Header */
        header {
            position: relative;
            height: 600px;
            color: #fff;
        }

        .header-background {
            background-image: url('../../Content/images/grade-12e3-fun-picture.jpg');
            background-size: cover;
            background-position: center;
            height: 600px;
            width: 100%;
            position: absolute;
            top: 0;
            left: 0;
            z-index: -1;
            filter: brightness(0.6);
            animation: fadeIn 2s ease-in-out;
        }

        keyframes fadeIn {
            from

        {
            opacity: 0;
        }

        to {
            opacity: 1;
        }

        }

        header .header-content {
            text-align: center;
            padding-top: 200px;
        }

            header .header-content h1 {
                font-size: 64px;
                margin: 0;
                text-shadow: 2px 2px 4px #000;
            }

            header .header-content p {
                font-size: 28px;
                margin: 20px 0;
                text-shadow: 1px 1px 3px #000;
            }
        /* Sections */
        section {
            padding: 60px 0;
        }

        .section-light {
            background-color: #fff;
            color: #333;
        }

        .section-dark {
            background-color: #222;
            color: #fff;
        }

            .section-dark h2 {
                color: #ff6600;
            }

        .section-content {
            margin-top: 20px;
        }
        /* Buttons */
        .btn-custom {
            background-color: #ff6600;
            color: #fff;
            border: none;
            font-weight: bold;
        }

            .btn-custom:hover {
                background-color: #e65c00;
                color: #fff;
            }
        /* Footer */
        footer {
            background-color: #000;
            color: #ccc;
            padding: 20px 0;
        }

            footer h4 {
                color: #ff6600;
            }

            footer a {
                color: #ff6600;
            }

                footer a:hover {
                    color: #fff;
                }
        /* Animations */
        .fade-in {
            animation: fadeIn 1.5s ease-in-out;
        }
    </style>
</head>
