@model List<Avonford_Secondary_School.Models.ViewModels.StudentTransferTrackingVM>
@{
    ViewBag.Title = "My Transfer Requests";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container mt-4">
    <h2 class="mb-3 text-primary">My Stream Transfer Requests</h2>
    @if (Model.Count == 0)
    {
        <div class="alert alert-info">You have not submitted any transfer requests yet.</div>
    }
    else
    {
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Date Submitted</th>
                    <th>From</th>
                    <th>To</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var req in Model)
                {
                    <tr>
                        <td>@req.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@req.OldGrade (@req.OldStream)</td>
                        <td>@req.NewGrade (@req.NewStream)</td>
                        <td>
                            <span class="badge badge-info">@req.Status</span>
                        </td>
                        <td>
                            <a class="btn btn-sm btn-outline-success" href="@Url.Action("TrackTransferRequest", "Student", new { id = req.TransferRequestID })">
                                Track Status
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
