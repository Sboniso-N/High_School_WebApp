@model Avonford_Secondary_School.Models.ViewModels.ConfirmAttemptViewModel

@{
    ViewBag.Title = "Confirm Assessment Attempt";
    Layout = null; // You can switch this back to "~/Views/Shared/_Layout.cshtml" if you already have a global layout
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css" />
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: #f9f9f9;
        }

        .navbar-custom {
            background-color: #ff6600;
            border: none;
            border-radius: 0;
            margin-bottom: 0;
        }

            .navbar-custom .navbar-brand {
                color: #fff !important;
                font-size: 24px;
                font-weight: bold;
            }

            .navbar-custom .navbar-nav > li > a {
                color: #fff !important;
                font-size: 16px;
            }

                .navbar-custom .navbar-nav > li > a:hover {
                    color: #222 !important;
                }

        .container {
            padding: 30px 20px;
        }

        h2 {
            margin-bottom: 30px;
            color: #333;
        }

        .alert-info {
            background-color: #f1f1f1;
            border-left: 5px solid #ff6600;
            padding: 20px;
            font-size: 16px;
        }

        .btn-primary {
            background-color: #ff6600;
            border-color: #ff6600;
        }

            .btn-primary:hover {
                background-color: #e65c00;
                border-color: #e65c00;
            }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-custom">
        <div class="container">
            <div class="navbar-header">
                <a class="navbar-brand" href="/Student/Index">Avonford Secondary School</a>
            </div>
            <ul class="nav navbar-nav navbar-right">
                <li><a href="/Student/Index">Dashboard</a></li>
                <li><a href="/Account/Logout">Logout</a></li>
            </ul>
        </div>
    </nav>

    <div class="container">
        <h2>Assessment Instructions</h2>

        <div class="alert alert-info">
            <p><strong>Assessment Name:</strong> @Model.AssessmentName</p>
            <p><strong>Date:</strong> @Model.AssessmentDate.ToString("yyyy-MM-dd")</p>
            <p><strong>End Time:</strong> @Model.EndTime.ToString(@"hh\:mm")</p>
            <p><strong>Instructions:</strong></p>
            <p>@Model.Instructions</p>
        </div>

        @using (Html.BeginForm("ConfirmAttempt", "Student", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.AttemptID)
            <input type="submit" value="Confirm Start" class="btn btn-primary" />
        }
    </div>

</body>
</html>
