@model Avonford_Secondary_School.Models.ViewModels.StudentClassDetailVM
@{
    ViewBag.Title = "Pay for Class";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var stripeKey = System.Configuration.ConfigurationManager.AppSettings["StripePublishableKey"];
}
<div class="container py-4">
    <h2>Pay for @Model.ClassName</h2>
    <p><b>Class:</b> @Model.ClassName</p>
    <p><b>Tutor:</b> @Model.TutorName</p>
    <p><b>Subject:</b> @Model.SubjectName</p>
    <p><b>Grade:</b> @Model.GradeName</p>
    <p><b>Fee:</b> <span class="badge bg-success">R @Model.AnnualFee.ToString("F2")</span></p>
    <form action="@Url.Action("PayForClass", "Student", new { classId = Model.TutorClassID })" method="get">
        <button type="submit" class="btn btn-success btn-lg">Pay with Stripe</button>
    </form>
    <p class="mt-3 text-muted">You will be redirected to a secure Stripe test checkout.</p>
</div>
