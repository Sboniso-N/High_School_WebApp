@model Avonford_Secondary_School.Models.ViewModels.StudentTutorInfoVM
@{
    ViewBag.Title = "Tutor Info";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container py-4">
    <div class="card shadow mx-auto" style="max-width:420px;">
        <div class="card-body text-center">
            <img src="@(Model.TutorProfilePic != null ? "data:image/jpeg;base64," + Model.TutorProfilePic : "/Content/img/no-profile.png")" class="rounded-circle mb-2" style="width:110px;height:110px;object-fit:cover;">
            <h3>@Model.TutorName</h3>
            <hr>
            <p><b>Qualifications:</b> @Model.Qualifications</p>
            <p><b>Email:</b> <a href="mailto:@Model.Email">@Model.Email</a></p>
            <p><b>Phone:</b> <a href="tel:@Model.Phone">@Model.Phone</a></p>
            <h5>Bio</h5>
            <p>@Model.Bio</p>
        </div>
    </div>
</div>
