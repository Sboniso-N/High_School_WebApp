@model Avonford_Secondary_School.Models.ViewModels.StudentMyClassesListVM
@{
    ViewBag.Title = "My Tutor Classes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container py-4">
    <h2 class="mb-3">My Tutor Classes</h2>
    <div class="d-flex mb-3">
        <a href="@Url.Action("FindTutorClasses", "Student")" class="btn btn-primary">Find Tutor Class</a>
    </div>
    @if (Model.PaidClasses == null || !Model.PaidClasses.Any())
    {
        <div class="alert alert-info">You are not enrolled in any tutor classes yet. Click "Find Tutor Class" to browse available classes.</div>
    }
    else
    {
        <div class="row">
            @foreach (var c in Model.PaidClasses)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow border-0">
                        <img src="@(c.CoverImageBase64 != null ? "data:image/jpeg;base64," + c.CoverImageBase64 : "/Content/img/no-class-image.png")"
                             alt="Class Image" class="card-img-top" style="object-fit:cover;height:170px;">
                        <div class="card-body">
                            <h5 class="card-title">@c.ClassName</h5>
                            <span class="badge bg-secondary mb-2">@c.SubjectName | @c.GradeName</span>
                            <div class="d-flex align-items-center mb-2">
                                <img src="@(c.TutorProfilePic != null ? "data:image/jpeg;base64," + c.TutorProfilePic : "/Content/img/no-profile.png")"
                                     class="rounded-circle" style="width:36px;height:36px;object-fit:cover;margin-right:10px;">
                                <span>@c.TutorName</span>
                            </div>
                            <span class="badge bg-success">Slots Left: @(c.Capacity - c.Enrolled)</span>
                            <p class="mt-2"><strong>Fee:</strong> R @c.AnnualFee.ToString("F2")</p>
                            <a href="@Url.Action("ClassDetails", "Student", new { classId = c.TutorClassID })" class="btn btn-outline-info btn-block w-100 mt-2">View Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
