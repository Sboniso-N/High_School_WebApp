@model Avonford_Secondary_School.Models.ViewModels.QRCodeVM
@{
    ViewBag.Title = "Attendance QR";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container py-4 text-center">
    <h2>Show this QR code to your tutor for attendance</h2>
    <img src="data:image/png;base64,@Convert.ToBase64String(Model.QRImageBytes)" style="width: 260px; height: 260px;" />
    <div class="mt-3">
        <a href="@Url.Action("AttendanceConfirmation", "Student", new { sessionId = ViewBag.SessionId })" class="btn btn-success">Continue</a>
    </div>
</div>
